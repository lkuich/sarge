generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  ownerUserId String?  @unique
  createdAt   DateTime @default(now())
  sites       Site[]
}

model Site {
  id                 String   @id @default(cuid())
  workspaceId        String
  slug               String
  name               String
  endpointHost       String   @unique
  attributionTtlDays Int      @default(28)
  pixelEnabled       Boolean  @default(true)
  createdAt          DateTime @default(now())
  events             Event[]
  diagnosticRuns     DiagnosticRun[]
  diagnosticFindings DiagnosticFinding[]
  webhookEndpoints   WebhookEndpoint[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, slug])
}

model Affiliate {
  id        String   @id
  name      String
  rate      Decimal?
  createdAt DateTime @default(now())
}

model Event {
  id                   String   @id @default(cuid())
  siteId               String
  name                 String
  occurredAt           DateTime
  sessionId            String
  userId               String
  ref                  String?
  affiliate            String?
  attributionExpiresAt DateTime?
  url                  String?
  referrer             String?
  title                String?
  properties           Json     @default("{}")
  receivedAt           DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, occurredAt])
  @@index([name, occurredAt])
  @@index([sessionId])
  @@index([userId])
}

model DiagnosticRun {
  id               String              @id
  siteId           String
  status           String
  eventWindowStart DateTime
  eventWindowEnd   DateTime
  findingCount     Int                 @default(0)
  aiSummary        String?
  startedAt        DateTime
  completedAt      DateTime
  createdAt        DateTime            @default(now())
  findings         DiagnosticFinding[]

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
  @@index([status, createdAt])
}

model DiagnosticFinding {
  id             String   @id
  runId          String
  siteId         String
  ruleId         String
  severity       String
  title          String
  summary        String
  evidence       Json     @default("[]")
  recommendation String
  agentPrompt    String
  createdAt      DateTime @default(now())

  run  DiagnosticRun @relation(fields: [runId], references: [id])
  site Site          @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
  @@index([runId])
  @@index([ruleId, severity])
}

model WebhookEndpoint {
  id            String   @id
  siteId        String
  name          String
  url           String
  eventNames    Json     @default("[]")
  signingSecret String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
  @@index([isActive])
}
