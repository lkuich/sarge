generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  name                    String
  ownerUserId             String?  @unique
  planId                  String   @default("free")
  billingStatus           String   @default("active")
  currentPeriodStart      DateTime @default(now())
  currentPeriodEventCount Int      @default(0)
  createdAt               DateTime @default(now())
  sites                   Site[]
}

model Site {
  id                    String              @id @default(cuid())
  workspaceId           String
  slug                  String
  name                  String
  endpointHost          String              @unique
  attributionTtlDays    Int                 @default(28)
  pixelEnabled          Boolean             @default(true)
  serverEventSecretHash String?
  postbackTokenHash     String?
  createdAt             DateTime            @default(now())
  events                Event[]
  diagnosticRuns        DiagnosticRun[]
  diagnosticFindings    DiagnosticFinding[]
  webhookEndpoints      WebhookEndpoint[]
  environments          SiteEnvironment[]
  projectShares         ProjectShare[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, slug])
}

model SiteEnvironment {
  id                    String              @id
  siteId                String
  environment           String
  endpointHost          String              @unique
  attributionTtlDays    Int                 @default(28)
  pixelEnabled          Boolean             @default(true)
  serverEventSecretHash String?
  postbackTokenHash     String?
  createdAt             DateTime            @default(now())
  events                Event[]
  diagnosticRuns        DiagnosticRun[]
  diagnosticFindings    DiagnosticFinding[]
  webhookEndpoints      WebhookEndpoint[]

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, environment])
  @@index([environment, pixelEnabled])
}

model Affiliate {
  id        String   @id
  name      String
  rate      Decimal?
  createdAt DateTime @default(now())
}

model Event {
  id                   String    @id @default(cuid())
  siteId               String
  siteEnvironmentId    String
  source               String    @default("browser")
  name                 String
  occurredAt           DateTime
  sessionId            String
  userId               String
  ref                  String?
  affiliate            String?
  attributionExpiresAt DateTime?
  url                  String?
  referrer             String?
  title                String?
  properties           Json      @default("{}")
  receivedAt           DateTime  @default(now())

  site            Site            @relation(fields: [siteId], references: [id])
  siteEnvironment SiteEnvironment @relation(fields: [siteEnvironmentId], references: [id])

  @@index([siteId, occurredAt])
  @@index([siteEnvironmentId, occurredAt])
  @@index([siteId, source, occurredAt])
  @@index([name, occurredAt])
  @@index([sessionId])
  @@index([userId])
}

model DiagnosticRun {
  id               String              @id
  siteId           String
  siteEnvironmentId String
  status           String
  eventWindowStart DateTime
  eventWindowEnd   DateTime
  findingCount     Int                 @default(0)
  aiSummary        String?
  startedAt        DateTime
  completedAt      DateTime
  createdAt        DateTime            @default(now())
  findings         DiagnosticFinding[]

  site            Site            @relation(fields: [siteId], references: [id])
  siteEnvironment SiteEnvironment @relation(fields: [siteEnvironmentId], references: [id])

  @@index([siteId, createdAt])
  @@index([siteEnvironmentId, createdAt])
  @@index([status, createdAt])
}

model DiagnosticFinding {
  id             String   @id
  runId          String
  siteId         String
  siteEnvironmentId String
  ruleId         String
  severity       String
  title          String
  summary        String
  evidence       Json     @default("[]")
  recommendation String
  agentPrompt    String
  createdAt      DateTime @default(now())

  run             DiagnosticRun   @relation(fields: [runId], references: [id])
  site            Site            @relation(fields: [siteId], references: [id])
  siteEnvironment SiteEnvironment @relation(fields: [siteEnvironmentId], references: [id])

  @@index([siteId, createdAt])
  @@index([siteEnvironmentId, createdAt])
  @@index([runId])
  @@index([ruleId, severity])
}

model WebhookEndpoint {
  id            String   @id
  siteId        String
  siteEnvironmentId String
  name          String
  url           String
  eventNames    Json     @default("[]")
  signingSecret String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  site            Site            @relation(fields: [siteId], references: [id])
  siteEnvironment SiteEnvironment @relation(fields: [siteEnvironmentId], references: [id])

  @@index([siteId, createdAt])
  @@index([siteEnvironmentId, createdAt])
  @@index([isActive])
}

model ProjectShare {
  id              String    @id @default(cuid())
  siteId          String
  email           String
  role            String
  invitedByUserId String
  acceptedUserId  String?
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, email])
  @@index([email])
  @@index([acceptedUserId])
}
