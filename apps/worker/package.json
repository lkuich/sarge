{
  "name": "@sarge/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "pnpm --filter @sarge/core build && pnpm --filter @sarge/pixel build && node ../../scripts/embed-pixel.mjs && wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@sarge/core": "workspace:*",
    "@sarge/pixel": "workspace:*",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.0",
    "wrangler": "^4.50.0"
  }
}
