---
import { AlertTriangle, ArrowRight, Home, LifeBuoy, Search, TerminalSquare } from "lucide-react";
import SiteLayout from "@/layouts/SiteLayout.astro";

interface StatusItem {
  label: string;
  value: string;
  tone?: "danger" | "warning" | "success";
}

interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  statusCode: "404" | "500";
  title: string;
  eyebrow: string;
  heading: string;
  description: string;
  primaryAction: Action;
  secondaryAction: Action;
  statusPanelId: string;
  statusItems: StatusItem[];
}

const { statusCode, title, eyebrow, heading, description, primaryAction, secondaryAction, statusPanelId, statusItems } = Astro.props;
const isMissingRoute = statusCode === "404";
const statusTone = isMissingRoute ? "text-amber-300" : "text-red-300";
---

<SiteLayout title={title} showFooter={false}>
  <section class="relative isolate flex min-h-[calc(100svh-4rem)] items-center overflow-hidden px-4 py-12 md:px-6">
    <div class="absolute inset-0 -z-10" aria-hidden="true"></div>
    <div class="absolute inset-x-0 top-12 -z-10 h-px bg-gradient-to-r from-transparent via-primary/45 to-transparent" aria-hidden="true"></div>

    <div class="mx-auto grid w-full max-w-6xl items-center gap-8 lg:grid-cols-[minmax(0,1fr)_25rem]">
      <div class="max-w-3xl">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.32em] text-primary">{eyebrow}</p>
        <div class="mt-5 flex flex-wrap items-end gap-x-5 gap-y-3">
          <span class={`font-mono text-7xl font-semibold leading-none md:text-8xl ${statusTone}`}>{statusCode}</span>
          <h1 class="max-w-2xl text-4xl font-semibold leading-tight md:text-6xl">{heading}</h1>
        </div>
        <p class="mt-6 max-w-2xl text-base leading-7 text-muted-foreground md:text-lg">{description}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            class="inline-flex h-11 items-center justify-center gap-2 rounded-md bg-primary px-4 text-sm font-semibold text-primary-foreground transition hover:bg-primary/85 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
            href={primaryAction.href}
          >
            <Home className="size-4" />
            {primaryAction.label}
          </a>
          <a
            class="inline-flex h-11 items-center justify-center gap-2 rounded-md border bg-background/65 px-4 text-sm font-semibold text-foreground backdrop-blur transition hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
            href={secondaryAction.href}
          >
            {isMissingRoute ? <Search className="size-4" /> : <LifeBuoy className="size-4" />}
            {secondaryAction.label}
            <ArrowRight className="size-4" />
          </a>
        </div>
      </div>

      <aside id={statusPanelId} class="rounded-lg border bg-card/80 p-5 shadow-2xl shadow-black/20 backdrop-blur">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted-foreground">Sarge monitor</p>
            <h2 class="mt-2 text-xl font-semibold">Page health check</h2>
          </div>
          <span class="grid size-11 place-items-center rounded-md border bg-muted">
            {isMissingRoute ? <TerminalSquare className="size-5 text-primary" /> : <AlertTriangle className="size-5 text-destructive" />}
          </span>
        </div>

        <dl class="mt-6 divide-y divide-border rounded-md border bg-background/70">
          {
            statusItems.map((item) => (
              <div class="grid grid-cols-[8rem_1fr] gap-3 px-4 py-3">
                <dt class="font-mono text-xs uppercase tracking-[0.16em] text-muted-foreground">{item.label}</dt>
                <dd
                  class:list={[
                    "text-sm font-medium",
                    item.tone === "danger" && "text-red-300",
                    item.tone === "warning" && "text-amber-300",
                    item.tone === "success" && "text-emerald-300",
                  ]}
                >
                  {item.value}
                </dd>
              </div>
            ))
          }
        </dl>

        <p class="mt-5 text-sm leading-6 text-muted-foreground">
          Sarge keeps checking production URLs for 404s, 500s, timeouts, and redirect trouble so teams can hand the exact evidence to their coding agent.
        </p>
      </aside>
    </div>
  </section>
</SiteLayout>
