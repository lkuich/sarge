---
import { UserButton } from "@clerk/astro/components";
import { ChevronRight, ExternalLink, Home } from "lucide-react";
import type { SargeAccount } from "@/lib/sarge-demo";
import ThemeToggle from "@/components/ThemeToggle";
import { THEME_INIT_SCRIPT } from "@/lib/theme";
import "../styles/global.css";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface HeadingLink {
  label: string;
  href: string;
}

interface Props {
  account: SargeAccount;
  title?: string;
  eyebrow?: string;
  heading: string;
  headingLink?: HeadingLink;
  description?: string;
  active: "overview" | "account" | "notifications" | "billing";
  breadcrumbs?: BreadcrumbItem[];
}

const { account, title = "Sarge", eyebrow = account.name, heading, headingLink, description, active, breadcrumbs = [] } = Astro.props;

---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <script is:inline set:html={THEME_INIT_SCRIPT} />
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen bg-background/80">
      <header class="sticky top-0 z-10 border-b bg-background/90 backdrop-blur">
        <div class="mx-auto flex min-h-16 w-full max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3 md:px-6">
          <div class="flex min-w-0 items-center gap-4">
            <a class="flex shrink-0 items-center" href="/app" aria-label="Sarge home">
              <img class="h-7 w-auto dark:hidden" src="/sarge-logo-light.svg" alt="Sarge" width="196" height="48" />
              <img class="hidden h-7 w-auto dark:block" src="/sarge-logo-dark.svg" alt="Sarge" width="196" height="48" />
            </a>
            <nav class="flex items-center gap-1" aria-label="Application">
              <a
                class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition hover:bg-accent hover:text-accent-foreground"
                href="/docs"
              >
                Docs
              </a>
              <a
                href="/app/notifications"
                class:list={[
                  "rounded-md px-3 py-2 text-sm font-medium transition",
                  active === "notifications"
                    ? "bg-primary text-primary-foreground"
                    : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
                ]}
              >
                Notifications
              </a>
              <a
                href="/app/billing"
                class:list={[
                  "rounded-md px-3 py-2 text-sm font-medium transition",
                  active === "billing"
                    ? "bg-primary text-primary-foreground"
                    : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
                ]}
              >
                Billing
              </a>
            </nav>
          </div>
          <div class="flex min-w-0 items-center gap-3">
            <div class="hidden min-w-0 text-right sm:block">
              <p class="truncate text-sm font-semibold">{account.name}</p>
              <p class="text-xs text-muted-foreground">{account.role} · {account.plan.name}</p>
            </div>
            <ThemeToggle client:only="react" />
            <UserButton />
          </div>
        </div>
      </header>

      <main class="mx-auto w-full max-w-6xl px-4 py-6 md:px-6 md:py-8">
        <header class="mb-6">
          {
            breadcrumbs.length > 0 && (
              <nav class="mb-4 flex min-w-0 items-center gap-1 text-sm text-muted-foreground" aria-label="Breadcrumb">
                <a class="inline-flex items-center gap-1 rounded-md px-1.5 py-1 transition hover:bg-accent hover:text-accent-foreground" href="/app">
                  <Home className="size-3.5" />
                  <span class="sr-only">Overview</span>
                </a>
                {breadcrumbs.map((item, index) => (
                  <>
                    <ChevronRight className="size-3.5 shrink-0 text-muted-foreground/70" />
                    {item.href && index !== breadcrumbs.length - 1 ? (
                      <a class="truncate rounded-md px-1.5 py-1 transition hover:bg-accent hover:text-accent-foreground" href={item.href}>
                        {item.label}
                      </a>
                    ) : (
                      <span class="truncate px-1.5 py-1 font-medium text-foreground" aria-current="page">
                        {item.label}
                      </span>
                    )}
                  </>
                ))}
              </nav>
            )
          }
          <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">{eyebrow}</p>
          <h1 class="mt-2 flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1 text-3xl font-semibold tracking-tight md:text-4xl">
            <span class="min-w-0 break-words">{heading}</span>
            {headingLink && (
              <a
                class="inline-flex max-w-full items-center gap-1 truncate font-mono text-sm font-medium text-muted-foreground underline-offset-4 transition hover:text-foreground hover:underline md:text-base"
                href={headingLink.href}
                target="_blank"
                rel="noreferrer"
                aria-label={`Open ${headingLink.label}`}
              >
                <span class="truncate">{headingLink.label}</span>
                <ExternalLink className="size-3.5 shrink-0" />
              </a>
            )}
          </h1>
          {description && <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{description}</p>}
        </header>

        <slot />
      </main>
    </div>
  </body>
</html>
