---
import { UserButton } from "@clerk/astro/components";
import { ChevronRight, Home } from "lucide-react";
import type { SargeAccount } from "@/lib/sarge-demo";
import ThemeToggle from "@/components/ThemeToggle";
import { THEME_INIT_SCRIPT } from "@/lib/theme";
import "../styles/global.css";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  account: SargeAccount;
  title?: string;
  eyebrow?: string;
  heading: string;
  description?: string;
  active: "overview" | "projects" | "account" | "admin";
  breadcrumbs?: BreadcrumbItem[];
}

const { account, title = "Sarge", eyebrow = account.name, heading, description, active, breadcrumbs = [] } = Astro.props;

const navItems = [
  { id: "overview", href: "/app", label: "Overview" },
  ...(account.workspaceSetupComplete
    ? [
        { id: "projects", href: "/app/projects", label: "Projects" },
        { id: "account", href: "/app/account", label: "Account" },
      ]
    : []),
  ...(account.workspaceSetupComplete && account.role === "admin" ? [{ id: "admin", href: "/admin", label: "Admin" }] : []),
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <script is:inline set:html={THEME_INIT_SCRIPT} />
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen bg-background/80">
      <aside class="fixed inset-y-0 left-0 hidden w-64 border-r bg-card/90 px-4 py-5 backdrop-blur lg:block">
        <a class="flex items-center px-2" href="/app" aria-label="Sarge home">
          <img class="h-8 w-auto dark:hidden" src="/sarge-logo-light.svg" alt="Sarge" width="196" height="48" />
          <img class="hidden h-8 w-auto dark:block" src="/sarge-logo-dark.svg" alt="Sarge" width="196" height="48" />
        </a>

        <div class="mt-8 rounded-lg border bg-secondary/50 p-3">
          <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Account</p>
          <p class="mt-1 truncate text-sm font-semibold">{account.name}</p>
          <p class="mt-1 text-xs text-muted-foreground">{account.role} · {account.plan}</p>
        </div>

        <nav class="mt-6 grid gap-1" aria-label="Application">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "rounded-md px-3 py-2 text-sm font-medium transition",
                  active === item.id
                    ? "bg-primary text-primary-foreground"
                    : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </aside>

      <div class="lg:pl-64">
        <header class="sticky top-0 z-10 border-b bg-background/90 backdrop-blur">
          <div class="flex min-h-16 items-center justify-between gap-4 px-4 md:px-6">
            <div class="min-w-0">
              <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">{eyebrow}</p>
              <p class="truncate text-sm font-semibold lg:hidden">{heading}</p>
            </div>
            <div class="flex items-center gap-3">
              <span class="hidden rounded-full border bg-card px-3 py-1 text-xs font-medium text-muted-foreground sm:inline-flex">
                {account.role}
              </span>
              <ThemeToggle client:load />
              <UserButton />
            </div>
          </div>
        </header>

        <main class="mx-auto w-full max-w-6xl px-4 py-6 md:px-6 md:py-8">
          <header class="mb-6">
            {
              breadcrumbs.length > 0 && (
                <nav class="mb-4 flex min-w-0 items-center gap-1 text-sm text-muted-foreground" aria-label="Breadcrumb">
                  <a class="inline-flex items-center gap-1 rounded-md px-1.5 py-1 transition hover:bg-accent hover:text-accent-foreground" href="/app">
                    <Home className="size-3.5" />
                    <span class="sr-only">Overview</span>
                  </a>
                  {breadcrumbs.map((item, index) => (
                    <>
                      <ChevronRight className="size-3.5 shrink-0 text-muted-foreground/70" />
                      {item.href && index !== breadcrumbs.length - 1 ? (
                        <a class="truncate rounded-md px-1.5 py-1 transition hover:bg-accent hover:text-accent-foreground" href={item.href}>
                          {item.label}
                        </a>
                      ) : (
                        <span class="truncate px-1.5 py-1 font-medium text-foreground" aria-current="page">
                          {item.label}
                        </span>
                      )}
                    </>
                  ))}
                </nav>
              )
            }
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">{eyebrow}</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight md:text-4xl">{heading}</h1>
            {description && <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{description}</p>}
          </header>

          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
