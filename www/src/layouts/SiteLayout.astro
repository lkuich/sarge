---
import { Show, UserButton } from "@clerk/astro/components";
import ThemeToggle from "@/components/ThemeToggle";
import { THEME_INIT_SCRIPT } from "@/lib/theme";
import "../styles/global.css";

interface Props {
  title?: string;
  shader?: boolean;
  showFooter?: boolean;
  showThemeToggle?: boolean;
}

const { title = "Sarge", shader = false, showFooter: showFooterProp, showThemeToggle = true } = Astro.props;
const showFooter = showFooterProp ?? !shader;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <script is:inline set:html={THEME_INIT_SCRIPT} />
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class:list={[{ "site-shell": shader }]}>
    <slot name="background" />

    <header class="relative z-10 mx-auto flex min-h-16 w-full max-w-6xl items-center justify-between gap-3 px-4 py-3 md:gap-4 md:px-6">
      <a class="flex min-w-0 items-center gap-2" href="/" aria-label="Sarge home">
        <img class="h-8 w-auto sm:h-9 dark:hidden" src="/sarge-logo-light.svg" alt="Sarge" width="196" height="48" />
        <img class="hidden h-8 w-auto sm:h-9 dark:block" src="/sarge-logo-dark.svg" alt="Sarge" width="196" height="48" />
        <span class="rounded-sm border border-primary/30 bg-primary/10 px-1.5 py-0.5 text-[10px] font-semibold leading-none text-primary">BETA</span>
      </a>

      <nav class="flex shrink-0 items-center justify-end gap-1 sm:gap-2" aria-label="Site">
        <a class="hidden rounded-md px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-accent hover:text-accent-foreground sm:inline-flex" href="/docs">
          Docs
        </a>
        <Show when="signed-out">
          <div class="flex items-center gap-2">
            <a class="hidden rounded-md px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-accent hover:text-accent-foreground sm:inline-flex" href="/sign-in">
              Sign in
            </a>
            <a class="whitespace-nowrap rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/80" href="/sign-up">
              Sign up
            </a>
          </div>
        </Show>
        <Show when="signed-in">
          <a class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-accent hover:text-accent-foreground" href="/app">
            Dashboard
          </a>
          <div data-site-account-profile class="grid size-8 shrink-0 place-items-center" role="group" aria-label="Account profile">
            <UserButton />
          </div>
        </Show>
        {showThemeToggle && <ThemeToggle client:only="react" />}
      </nav>
    </header>

    <main class="relative z-10">
      <slot />
    </main>

    {
      showFooter && (
        <footer class="relative z-10 border-t bg-background/80 px-4 py-8 text-sm text-muted-foreground md:px-6">
          <div class="mx-auto flex max-w-6xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p>© 2026 Sarge. All rights reserved.</p>
            <nav class="flex flex-wrap items-center gap-x-4 gap-y-2" aria-label="Legal">
              <a class="transition hover:text-foreground" href="/legal/privacy">Privacy Policy</a>
              <a class="transition hover:text-foreground" href="/legal/terms">Terms of Service</a>
              <a class="transition hover:text-foreground" href="mailto:privacy@sargetrack.app">Privacy requests</a>
            </nav>
          </div>
        </footer>
      )
    }
  </body>
</html>
