---
import { env } from "cloudflare:workers";
import { AlertCircle, CheckCircle2 } from "lucide-react";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import AppLayout from "@/layouts/AppLayout.astro";
import { getViewerAccount } from "@/lib/sarge-demo";
import { planDefinitions, type PlanId } from "@/lib/pricing";
import { createBillingPortalSession, createCheckoutSession } from "@/lib/stripe-billing";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");
const currentUser = await Astro.locals.currentUser();
const viewerEmails = currentUser?.emailAddresses.map((email) => email.emailAddress).filter(Boolean) ?? [];
const customerEmail = currentUser?.primaryEmailAddress?.emailAddress ?? viewerEmails[0] ?? null;

let billingError: string | null = null;
const checkoutStatus = new URL(Astro.request.url).searchParams.get("checkout");

const normalizePlanId = (value: FormDataEntryValue | null) => {
  if (typeof value !== "string") return null;
  return planDefinitions.some((plan) => plan.id === value) ? (value as PlanId) : null;
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = formData.get("intent");

  if (intent === "checkout-plan") {
    const planId = normalizePlanId(formData.get("planId"));
    if (!planId) {
      billingError = "Choose a valid plan.";
    } else {
      const result = await createCheckoutSession({
        env,
        databaseUrl: env.DATABASE_URL,
        userId,
        customerEmail,
        appUrl: Astro.request.url,
        planId,
      });
      if (result.success) return Astro.redirect(result.url, 303);
      billingError = result.error;
    }
  } else if (intent === "billing-portal") {
    const result = await createBillingPortalSession({
      env,
      databaseUrl: env.DATABASE_URL,
      userId,
      appUrl: Astro.request.url,
    });
    if (result.success) return Astro.redirect(result.url, 303);
    billingError = result.error;
  }
}

const account = await getViewerAccount(userId, env.DATABASE_URL, { viewerEmails });

const planHighlights: Record<PlanId, string[]> = {
  free: ["50k events/month", "7-day retention", "1 project"],
  starter: ["250k events/month", "30-day retention", "3 projects"],
  growth: ["2M events/month", "90-day retention", "10 projects"],
  scale: ["10M events/month", "180-day retention", "25 projects"],
  enterprise: ["Custom events/month", "1-year+ retention", "Dedicated endpoint"],
};

const planNames: Record<PlanId, string> = {
  free: "Free",
  starter: "Starter",
  growth: "Growth",
  scale: "Scale",
  enterprise: "Enterprise",
};

const planPrices: Record<PlanId, string> = {
  free: "$0",
  starter: "$49",
  growth: "$149",
  scale: "$399",
  enterprise: "Contact us",
};
---

<AppLayout
  account={account}
  title="Billing | Sarge"
  heading="Billing"
  description="Pick the Sarge plan that matches your tracking assurance workflow."
  active="billing"
  breadcrumbs={[{ label: "Overview", href: "/app" }, { label: "Billing" }]}
>
  <section class="grid gap-4">
    {
      billingError && (
        <Alert variant="destructive">
          <AlertCircle className="size-4" />
          <AlertTitle>Billing action failed</AlertTitle>
          <AlertDescription>{billingError}</AlertDescription>
        </Alert>
      )
    }
    {
      checkoutStatus === "success" && (
        <Alert>
          <CheckCircle2 className="size-4" />
          <AlertTitle>Checkout complete</AlertTitle>
          <AlertDescription>Your plan will update after Stripe confirms the subscription.</AlertDescription>
        </Alert>
      )
    }
    {
      checkoutStatus === "canceled" && (
        <Alert>
          <AlertCircle className="size-4" />
          <AlertTitle>Checkout canceled</AlertTitle>
          <AlertDescription>No plan changes were made.</AlertDescription>
        </Alert>
      )
    }
    <Card>
      <CardHeader>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <CardTitle>Current plan</CardTitle>
            <p class="text-sm text-muted-foreground">
              {account.plan.name} / {account.billingStatus.replace("_", " ")}
            </p>
          </div>
          <form method="post">
            <input type="hidden" name="intent" value="billing-portal" />
            <Button type="submit" variant="outline" disabled={account.planId === "free" || account.planId === "enterprise"}>
              Manage billing
            </Button>
          </form>
        </div>
      </CardHeader>
    </Card>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-3 xl:grid-cols-5">
    {
      planDefinitions.map((plan) => (
        <Card className={plan.id === account.planId ? "border-primary" : ""}>
          <CardHeader>
            <div class="flex items-center justify-between gap-2">
              <CardTitle>{planNames[plan.id]}</CardTitle>
              {plan.id === account.planId && <Badge>Current</Badge>}
            </div>
            <p class="text-3xl font-semibold">{planPrices[plan.id]}</p>
            {plan.monthlyPriceUsd !== null && <p class="text-xs text-muted-foreground">per month</p>}
          </CardHeader>
          <CardContent className="grid gap-3 text-sm">
            <p class="min-h-12 text-muted-foreground">{plan.description}</p>
            <div class="grid gap-2">
              {planHighlights[plan.id].map((highlight) => (
                <p class="flex items-center gap-2">
                  <CheckCircle2 className="size-4 shrink-0 text-primary" /> {highlight}
                </p>
              ))}
            </div>
            {
              plan.monthlyPriceUsd === null ? (
                <a
                  class="inline-flex h-8 items-center justify-center rounded-lg bg-primary px-2.5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80"
                  href="mailto:hello@sargetrack.app?subject=Sarge%20Enterprise"
                >
                  Contact us
                </a>
              ) : plan.id === account.planId ? (
                <Button variant="outline" disabled>
                  Current plan
                </Button>
              ) : plan.id === "free" ? (
                <Button variant="outline" disabled>
                  Included
                </Button>
              ) : (
                <form method="post">
                  <input type="hidden" name="intent" value="checkout-plan" />
                  <input type="hidden" name="planId" value={plan.id} />
                  <Button type="submit">Choose plan</Button>
                </form>
              )
            }
          </CardContent>
        </Card>
      ))
    }
  </section>
</AppLayout>
