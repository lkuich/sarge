---
import { env } from "cloudflare:workers";
import { Activity, AlertTriangle, CheckCircle2, FolderPlus, Gauge, Plus } from "lucide-react";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import AppLayout from "@/layouts/AppLayout.astro";
import { getLimitUsagePrompt } from "@/lib/pricing";
import { canAdministerAccount, createWorkspace, deleteWorkspace, environmentLabels, formatCount, getAccountUsage, getViewerAccount } from "@/lib/sarge-demo";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");
const currentUser = await Astro.locals.currentUser();
const viewerEmails = currentUser?.emailAddresses.map((email) => email.emailAddress).filter(Boolean) ?? [];

let workspaceError = "";
let workspaceDeleteError = "";
let workspaceValues = {
  name: "",
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "create-workspace") {
    workspaceValues = {
      name: String(formData.get("workspaceName") ?? ""),
    };

    const result = await createWorkspace(userId, env.DATABASE_URL, workspaceValues);
    if (result.success) return Astro.redirect("/app", 303);

    workspaceError = result.error;
  }

  if (intent === "delete-workspace") {
    const result = await deleteWorkspace(userId, env.DATABASE_URL);
    if (result.success) return Astro.redirect("/app", 303);

    workspaceDeleteError = result.error;
  }
}

const account = await getViewerAccount(userId, env.DATABASE_URL, { viewerEmails });
const accountUsage = getAccountUsage(account);
const eventUsagePrompt = getLimitUsagePrompt({
  used: accountUsage.eventsThisPeriod,
  limit: accountUsage.eventLimit,
  noun: "events",
  planId: account.planId,
});
const projectUsagePrompt = getLimitUsagePrompt({
  used: accountUsage.projects,
  limit: accountUsage.projectLimit,
  noun: "projects",
  planId: account.planId,
});
const usagePrompts = [eventUsagePrompt, projectUsagePrompt].filter((prompt) => prompt !== null);
const totalEvents = account.projects.reduce((sum, project) => sum + project.eventCount24h, 0);
const failedEvents = account.projects.reduce((sum, project) => sum + project.failedEvents24h, 0);
const hasProjects = account.projects.length > 0;
const hasOwnedProjects = account.ownedProjects.length > 0;
const hasSharedProjects = account.sharedProjects.length > 0;
const needsWorkspaceSetup = !account.workspaceSetupComplete;
const shouldShowSetupGuide = needsWorkspaceSetup || !hasOwnedProjects;
const canCreateProjects = canAdministerAccount(account);
const canDeleteWorkspace = canCreateProjects && account.workspaceSetupComplete && account.ownedProjects.length === 0;
const projectCountLabel = `${account.ownedProjects.length} ${account.ownedProjects.length === 1 ? "project" : "projects"} under ${account.name}`;
const activeProjects = account.projects.filter((project) => project.status === "active").length;
const collectingProjects = account.projects.filter((project) => project.eventCount24h > 0).length;
const attentionItems = account.projects.filter((project) => project.status !== "active").length + failedEvents;
const coveragePercent = hasProjects ? Math.round((collectingProjects / account.projects.length) * 100) : 0;
const failureRate = totalEvents > 0 ? Math.round((failedEvents / totalEvents) * 1000) / 10 : 0;
const busiestProject = [...account.projects].sort((left, right) => right.eventCount24h - left.eventCount24h).at(0);
const projectDistribution = buildProjectDistribution(account.projects);
const projectActivityScale = Math.max(1, ...account.projects.map((project) => project.eventCount24h));
const eventUsagePercent = accountUsage.eventLimit === null ? 0 : Math.min(100, Math.round((accountUsage.eventsThisPeriod / accountUsage.eventLimit) * 100));
const projectUsagePercent = accountUsage.projectLimit === null ? 0 : Math.min(100, Math.round((accountUsage.projects / accountUsage.projectLimit) * 100));

function buildProjectDistribution(projects: typeof account.projects) {
  const total = Math.max(1, projects.length);
  return [
    {
      label: "Active",
      value: projects.filter((project) => project.status === "active").length,
      className: "bg-emerald-500",
    },
    {
      label: "Draft",
      value: projects.filter((project) => project.status === "draft").length,
      className: "bg-chart-4",
    },
    {
      label: "Paused",
      value: projects.filter((project) => project.status === "paused").length,
      className: "bg-muted-foreground",
    },
  ].map((item) => ({
    ...item,
    share: Math.round((item.value / total) * 100),
  }));
}
---

<AppLayout
  account={account}
  title="Dashboard | Sarge"
  heading={needsWorkspaceSetup ? "Create your workspace" : "Overview"}
  description={needsWorkspaceSetup
    ? "Start by naming the workspace that will own your Sarge projects."
    : "Projects are grouped under your account. Admins manage access and setup; users inspect assigned projects and event flow."}
  active="overview"
  breadcrumbs={[{ label: "Overview" }]}
>
  {
    shouldShowSetupGuide && (
      <section class="mb-6">
        <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Setup guide</p>
            <h2 class="mt-1 text-xl font-semibold tracking-tight">Set up Sarge in two steps</h2>
          </div>
          <Badge variant={hasOwnedProjects ? "secondary" : "outline"}>{hasOwnedProjects ? "Project ready" : "New account"}</Badge>
        </div>
        <div class="grid gap-3 md:grid-cols-2">
          <Card className={needsWorkspaceSetup ? "border-primary/70" : ""}>
            <CardHeader className="pb-3">
              <div class="flex items-start gap-3">
                <span
                  class:list={[
                    "grid size-9 shrink-0 place-items-center rounded-md border",
                    needsWorkspaceSetup
                      ? "border-primary/40 bg-primary/10 text-primary"
                      : "border-emerald-500/30 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400",
                  ]}
                >
                  <CheckCircle2 className="size-4" />
                </span>
                <div class="min-w-0">
                  <CardTitle className="text-base">Create your workspace</CardTitle>
                  <p class="mt-1 text-sm leading-5 text-muted-foreground">This is the account your projects and events will live under.</p>
                </div>
              </div>
            </CardHeader>
            <CardContent className="pt-0">
              {
                needsWorkspaceSetup ? (
                  <>
                    {workspaceError && (
                      <Alert className="mb-4">
                        <AlertTitle>Workspace was not created</AlertTitle>
                        <AlertDescription>{workspaceError}</AlertDescription>
                      </Alert>
                    )}
                    <form method="post" class="grid gap-3">
                      <input type="hidden" name="intent" value="create-workspace" />
                      <div class="grid gap-2">
                        <Label htmlFor="workspaceName">Workspace name</Label>
                        <Input id="workspaceName" name="workspaceName" value={workspaceValues.name} placeholder="Acme Growth" required />
                      </div>
                      <div>
                        <Button type="submit">Create workspace</Button>
                      </div>
                    </form>
                  </>
                ) : (
                  <div class="grid gap-3">
                    <p class="text-sm font-medium">{account.name}</p>
                    {workspaceDeleteError && (
                      <Alert>
                        <AlertTitle>Workspace was not deleted</AlertTitle>
                        <AlertDescription>{workspaceDeleteError}</AlertDescription>
                      </Alert>
                    )}
                    <div class="rounded-md border bg-muted/30 p-3" data-delete-workspace>
                      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                          <p class="text-sm font-medium">Delete empty workspace</p>
                          <p class="mt-1 text-xs text-muted-foreground">
                            {canDeleteWorkspace ? "Only empty workspaces can be deleted." : "Remove projects first before deleting this workspace."}
                          </p>
                        </div>
                        <form method="post">
                          <input type="hidden" name="intent" value="delete-workspace" />
                          <Button type="submit" variant="outline" size="sm" disabled={!canDeleteWorkspace}>
                            Delete
                          </Button>
                        </form>
                      </div>
                    </div>
                  </div>
                )
              }
            </CardContent>
          </Card>

          <Card className={!needsWorkspaceSetup && !hasOwnedProjects ? "border-primary/70" : ""}>
            <CardHeader className="pb-3">
              <div class="flex items-start gap-3">
                <span
                  class:list={[
                    "grid size-9 shrink-0 place-items-center rounded-md border",
                    hasOwnedProjects
                      ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400"
                      : needsWorkspaceSetup
                        ? "bg-secondary text-muted-foreground"
                        : "border-primary/40 bg-primary/10 text-primary",
                  ]}
                >
                  {hasOwnedProjects ? <CheckCircle2 className="size-4" /> : <FolderPlus className="size-4" />}
                </span>
                <div class="min-w-0">
                  <CardTitle className="text-base">Add your project</CardTitle>
                  <p class="mt-1 text-sm leading-5 text-muted-foreground">Create the site or store you want to track first.</p>
                </div>
              </div>
            </CardHeader>
            <CardContent className="pt-0">
              {
                hasOwnedProjects ? (
                  <p class="text-sm font-medium">{account.ownedProjects[0].name}</p>
                ) : needsWorkspaceSetup ? (
                  <p class="text-sm text-muted-foreground">Create your workspace first.</p>
                ) : (
                  <a
                    class="inline-flex h-8 items-center justify-center rounded-md bg-primary px-2.5 text-sm font-medium text-primary-foreground transition hover:bg-primary/80"
                    href="/app/projects/new"
                  >
                    Add project
                  </a>
                )
              }
            </CardContent>
          </Card>
        </div>
      </section>
    )
  }

  {
    (!needsWorkspaceSetup || hasSharedProjects) && (
      <>
        <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-4" data-overview-metrics>
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Coverage</CardTitle>
              <Gauge className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{coveragePercent}%</p>
              <div class="mt-3 h-2 rounded-full bg-secondary">
                <div class="h-full rounded-full bg-emerald-500" style={`width: ${coveragePercent}%`} />
              </div>
              <p class="mt-2 text-xs text-muted-foreground">{collectingProjects} of {account.projects.length} projects receiving events</p>
            </CardContent>
          </Card>
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Throughput</CardTitle>
              <Activity className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{formatCount(totalEvents)}</p>
              <p class="text-xs text-muted-foreground">{busiestProject ? `${busiestProject.name} is busiest` : "No events in the last 24h"}</p>
            </CardContent>
          </Card>
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Attention</CardTitle>
              <AlertTriangle className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{attentionItems}</p>
              <p class="text-xs text-muted-foreground">{failedEvents} failed · {failureRate}% failure rate</p>
            </CardContent>
          </Card>
          <Card data-plan-usage-panel>
            <CardHeader className="pb-2">
              <CardTitle className="text-sm font-medium">Plan usage</CardTitle>
            </CardHeader>
            <CardContent className="grid gap-3 text-sm">
              <div class="flex items-center justify-between gap-3">
                <span class="text-muted-foreground">Projects</span>
                <span class="font-medium">
                  {formatCount(accountUsage.projects)} / {account.plan.limits.projects === null ? "Unlimited" : formatCount(account.plan.limits.projects)}
                </span>
              </div>
              {
                accountUsage.projectLimit !== null && (
                  <div class="h-1.5 rounded-full bg-secondary" aria-hidden="true">
                    <div class="h-full rounded-full bg-primary" style={`width: ${projectUsagePercent}%`} />
                  </div>
                )
              }
              <div class="flex items-center justify-between gap-3">
                <span class="text-muted-foreground">Events this month</span>
                <span class="font-medium">
                  {formatCount(accountUsage.eventsThisPeriod)} / {account.plan.limits.eventsPerMonth === null ? "Unlimited" : formatCount(account.plan.limits.eventsPerMonth)}
                </span>
              </div>
              {
                accountUsage.eventLimit !== null && (
                  <div class="h-1.5 rounded-full bg-secondary" aria-hidden="true">
                    <div class="h-full rounded-full bg-primary" style={`width: ${eventUsagePercent}%`} />
                  </div>
                )
              }
              {
                usagePrompts.map((prompt) => (
                  <div
                    class:list={[
                      "rounded-md border p-3 text-xs",
                      prompt.level === "blocked"
                        ? "border-destructive/40 bg-destructive/10 text-destructive"
                        : prompt.level === "urgent"
                          ? "border-amber-500/40 bg-amber-500/10 text-amber-900 dark:text-amber-200"
                          : "bg-muted/40 text-muted-foreground",
                    ]}
                    data-usage-limit-prompt={prompt.level}
                  >
                    <p class="font-medium">{prompt.message}</p>
                    {prompt.targetPlanName && <p class="mt-1">Next plan: {prompt.targetPlanName}.</p>}
                  </div>
                ))
              }
              <a class="text-sm font-medium text-primary hover:underline" href="/app/billing">
                {usagePrompts.length > 0 ? "Upgrade plan" : "View plans"}
              </a>
            </CardContent>
          </Card>
        </section>

        <section class="mt-6 grid gap-6">
          <div>
            <div class="mb-4 flex items-center justify-between gap-3">
              <div>
                <h2 class="text-lg font-semibold tracking-tight">Your workspace</h2>
                <p class="text-sm text-muted-foreground">{projectCountLabel}</p>
              </div>
              {
                canCreateProjects && (
                  <a
                    class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg bg-primary px-2.5 text-sm font-medium whitespace-nowrap text-primary-foreground transition-all hover:bg-primary/80 focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
                    href="/app/projects/new"
                  >
                    <Plus className="size-4" /> New project
                  </a>
                )
              }
            </div>

            {
              hasOwnedProjects ? (
                <div class="grid gap-4 md:grid-cols-2">
                  {account.ownedProjects.map((project) => (
                    <Card>
                      <CardHeader>
                        <div class="flex items-start justify-between gap-3">
                          <div class="min-w-0">
                            <CardTitle><a href={`/app/projects/${project.siteId}`}>{project.name}</a></CardTitle>
                            <p class="mt-1 truncate font-mono text-xs text-muted-foreground">{project.customDomain}</p>
                          </div>
                          <Badge variant={project.status === "active" ? "default" : "secondary"}>{project.status}</Badge>
                        </div>
                      </CardHeader>
                      <CardContent>
                        <div class="grid gap-4 text-sm">
                          <div class="h-2 rounded-full bg-secondary">
                            <div
                              class="h-full rounded-full bg-primary"
                              style={`width: ${Math.max(project.eventCount24h > 0 ? 8 : 2, Math.round((project.eventCount24h / projectActivityScale) * 100))}%`}
                            />
                          </div>
                          <div class="grid grid-cols-3 gap-3">
                            <div>
                              <p class="text-xs text-muted-foreground">Environment</p>
                              <p class="font-medium">{environmentLabels[project.environment]}</p>
                            </div>
                            <div>
                              <p class="text-xs text-muted-foreground">Events</p>
                              <p class="font-medium">{formatCount(project.eventCount24h)}</p>
                            </div>
                            <div>
                              <p class="text-xs text-muted-foreground">Last seen</p>
                              <p class="font-medium">{project.lastEventAt}</p>
                            </div>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              ) : (
                <div class="flex flex-col items-start gap-3 rounded-md border border-dashed p-5">
                  <div>
                    <p class="font-medium">No projects in your workspace</p>
                    <p class="mt-1 text-sm text-muted-foreground">Add a project to get install details, a tracking domain, and an event stream.</p>
                  </div>
                  {
                    canCreateProjects && (
                      <a
                        class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md bg-primary px-2.5 text-sm font-medium text-primary-foreground transition hover:bg-primary/80"
                        href="/app/projects/new"
                      >
                        <FolderPlus className="size-4" /> Add project
                      </a>
                    )
                  }
                </div>
              )
            }
          </div>

          <div>
            <div class="mb-4">
              <h2 class="text-lg font-semibold tracking-tight">Shared with you</h2>
              <p class="text-sm text-muted-foreground">Projects another workspace invited you to inspect or edit.</p>
            </div>

            {
              hasSharedProjects ? (
                <div class="grid gap-4 md:grid-cols-2">
                  {account.sharedProjects.map((project) => (
                    <Card>
                      <CardHeader>
                        <div class="flex items-start justify-between gap-3">
                          <div class="min-w-0">
                            <CardTitle><a href={`/app/projects/${project.siteId}`}>{project.name}</a></CardTitle>
                            <p class="mt-1 truncate font-mono text-xs text-muted-foreground">{project.customDomain}</p>
                            {project.workspaceName && <p class="mt-1 truncate text-xs text-muted-foreground">{project.workspaceName}</p>}
                          </div>
                          <Badge variant={project.shareRole === "edit" ? "default" : "secondary"}>{project.shareRole ?? "view"}</Badge>
                        </div>
                      </CardHeader>
                      <CardContent>
                        <div class="grid gap-4 text-sm">
                          <div class="h-2 rounded-full bg-secondary">
                            <div
                              class="h-full rounded-full bg-primary"
                              style={`width: ${Math.max(project.eventCount24h > 0 ? 8 : 2, Math.round((project.eventCount24h / projectActivityScale) * 100))}%`}
                            />
                          </div>
                          <div class="grid grid-cols-3 gap-3">
                            <div>
                              <p class="text-xs text-muted-foreground">Environment</p>
                              <p class="font-medium">{environmentLabels[project.environment]}</p>
                            </div>
                            <div>
                              <p class="text-xs text-muted-foreground">Events</p>
                              <p class="font-medium">{formatCount(project.eventCount24h)}</p>
                            </div>
                            <div>
                              <p class="text-xs text-muted-foreground">Last seen</p>
                              <p class="font-medium">{project.lastEventAt}</p>
                            </div>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              ) : (
                <div class="rounded-md border border-dashed p-5">
                  <p class="font-medium">No shared projects</p>
                  <p class="mt-1 text-sm text-muted-foreground">Invites from other workspaces will appear here.</p>
                </div>
              )
            }
          </div>
        </section>
      </>
    )
  }
</AppLayout>
