---
import { env } from "cloudflare:workers";
import { Activity, AlertTriangle, CheckCircle2, FolderPlus, Gauge, Plus, Radio, ShieldCheck } from "lucide-react";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import AppLayout from "@/layouts/AppLayout.astro";
import { canAdministerAccount, createWorkspace, environmentLabels, formatCount, getViewerAccount } from "@/lib/sarge-demo";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");

let workspaceError = "";
let workspaceValues = {
  name: "",
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "create-workspace") {
    workspaceValues = {
      name: String(formData.get("workspaceName") ?? ""),
    };

    const result = await createWorkspace(userId, env.DATABASE_URL, workspaceValues);
    if (result.success) return Astro.redirect("/app", 303);

    workspaceError = result.error;
  }
}

const account = await getViewerAccount(userId, env.DATABASE_URL);
const totalEvents = account.projects.reduce((sum, project) => sum + project.eventCount24h, 0);
const failedEvents = account.projects.reduce((sum, project) => sum + project.failedEvents24h, 0);
const hasProjects = account.projects.length > 0;
const needsWorkspaceSetup = !account.workspaceSetupComplete;
const shouldShowSetupGuide = needsWorkspaceSetup || !hasProjects;
const canCreateProjects = canAdministerAccount(account);
const projectCountLabel = `${account.projects.length} ${account.projects.length === 1 ? "project" : "projects"} under ${account.name}`;
const activeProjects = account.projects.filter((project) => project.status === "active").length;
const projectsWithRecentEvents = account.projects.filter((project) => project.eventCount24h > 0).length;
const accountFailureRate = totalEvents > 0 ? Math.round((failedEvents / totalEvents) * 1000) / 10 : 0;
const accountHealthScore = hasProjects
  ? Math.max(0, Math.round(((activeProjects + projectsWithRecentEvents) / (account.projects.length * 2)) * 100) - failedEvents * 4)
  : 0;
const projectActivityBars = buildProjectActivityBars(account.projects);
const statusBreakdown = buildStatusBreakdown(account.projects);
const busiestProject = [...account.projects].sort((left, right) => right.eventCount24h - left.eventCount24h).at(0);

function buildProjectActivityBars(projects: typeof account.projects) {
  const maxEvents = Math.max(1, ...projects.map((project) => project.eventCount24h));

  return projects.map((project) => ({
    ...project,
    share: Math.max(project.eventCount24h > 0 ? 8 : 2, Math.round((project.eventCount24h / maxEvents) * 100)),
  }));
}

function buildStatusBreakdown(projects: typeof account.projects) {
  const statuses = [
    { label: "Active", value: projects.filter((project) => project.status === "active").length, className: "bg-emerald-500" },
    { label: "Draft", value: projects.filter((project) => project.status === "draft").length, className: "bg-chart-4" },
    { label: "Paused", value: projects.filter((project) => project.status === "paused").length, className: "bg-muted-foreground" },
  ];
  const total = Math.max(1, projects.length);

  return statuses.map((status) => ({
    ...status,
    share: Math.round((status.value / total) * 100),
  }));
}
---

<AppLayout
  account={account}
  title="Dashboard | Sarge"
  heading={needsWorkspaceSetup ? "Create your workspace" : "Overview"}
  description={needsWorkspaceSetup
    ? "Start by naming the workspace that will own your Sarge projects."
    : "Projects are grouped under your account. Admins manage access and setup; users inspect assigned projects and event flow."}
  active="overview"
  breadcrumbs={[{ label: "Overview" }]}
>
  {
    shouldShowSetupGuide && (
      <section class="mb-6">
        <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Setup guide</p>
            <h2 class="mt-1 text-xl font-semibold tracking-tight">Set up Sarge in two steps</h2>
          </div>
          <Badge variant={hasProjects ? "secondary" : "outline"}>{hasProjects ? "Project ready" : "New account"}</Badge>
        </div>
        <div class="grid gap-3 md:grid-cols-2">
          <Card className={needsWorkspaceSetup ? "border-primary/70" : ""}>
            <CardHeader className="pb-3">
              <div class="flex items-start gap-3">
                <span
                  class:list={[
                    "grid size-9 shrink-0 place-items-center rounded-md border",
                    needsWorkspaceSetup
                      ? "border-primary/40 bg-primary/10 text-primary"
                      : "border-emerald-500/30 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400",
                  ]}
                >
                  <CheckCircle2 className="size-4" />
                </span>
                <div class="min-w-0">
                  <CardTitle className="text-base">Create your workspace</CardTitle>
                  <p class="mt-1 text-sm leading-5 text-muted-foreground">This is the account your projects and events will live under.</p>
                </div>
              </div>
            </CardHeader>
            <CardContent className="pt-0">
              {
                needsWorkspaceSetup ? (
                  <>
                    {workspaceError && (
                      <Alert className="mb-4">
                        <AlertTitle>Workspace was not created</AlertTitle>
                        <AlertDescription>{workspaceError}</AlertDescription>
                      </Alert>
                    )}
                    <form method="post" class="grid gap-3">
                      <input type="hidden" name="intent" value="create-workspace" />
                      <div class="grid gap-2">
                        <Label htmlFor="workspaceName">Workspace name</Label>
                        <Input id="workspaceName" name="workspaceName" value={workspaceValues.name} placeholder="Acme Growth" required />
                      </div>
                      <div>
                        <Button type="submit">Create workspace</Button>
                      </div>
                    </form>
                  </>
                ) : (
                  <p class="text-sm font-medium">{account.name}</p>
                )
              }
            </CardContent>
          </Card>

          <Card className={!needsWorkspaceSetup && !hasProjects ? "border-primary/70" : ""}>
            <CardHeader className="pb-3">
              <div class="flex items-start gap-3">
                <span
                  class:list={[
                    "grid size-9 shrink-0 place-items-center rounded-md border",
                    hasProjects
                      ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400"
                      : needsWorkspaceSetup
                        ? "bg-secondary text-muted-foreground"
                        : "border-primary/40 bg-primary/10 text-primary",
                  ]}
                >
                  {hasProjects ? <CheckCircle2 className="size-4" /> : <FolderPlus className="size-4" />}
                </span>
                <div class="min-w-0">
                  <CardTitle className="text-base">Add your project</CardTitle>
                  <p class="mt-1 text-sm leading-5 text-muted-foreground">Create the site or store you want to track first.</p>
                </div>
              </div>
            </CardHeader>
            <CardContent className="pt-0">
              {
                hasProjects ? (
                  <p class="text-sm font-medium">{account.projects[0].name}</p>
                ) : needsWorkspaceSetup ? (
                  <p class="text-sm text-muted-foreground">Create your workspace first.</p>
                ) : (
                  <a
                    class="inline-flex h-8 items-center justify-center rounded-md bg-primary px-2.5 text-sm font-medium text-primary-foreground transition hover:bg-primary/80"
                    href="/app/projects/new"
                  >
                    Add project
                  </a>
                )
              }
            </CardContent>
          </Card>
        </div>
      </section>
    )
  }

  {
    !needsWorkspaceSetup && (
      <>
        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Account health</CardTitle>
              <ShieldCheck className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{accountHealthScore}</p>
              <div class="mt-3 h-2 rounded-full bg-secondary">
                <div class="h-full rounded-full bg-emerald-500" style={`width: ${accountHealthScore}%`} />
              </div>
              <p class="mt-2 text-xs text-muted-foreground">{activeProjects} active · {projectsWithRecentEvents} receiving events</p>
            </CardContent>
          </Card>
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">24h events</CardTitle>
              <Radio className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{formatCount(totalEvents)}</p>
              <p class="text-xs text-muted-foreground">accepted across all projects</p>
            </CardContent>
          </Card>
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Watchlist</CardTitle>
              <AlertTriangle className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{failedEvents}</p>
              <p class="text-xs text-muted-foreground">{accountFailureRate}% failure rate</p>
            </CardContent>
          </Card>
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Projects</CardTitle>
              <Gauge className="size-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <p class="text-3xl font-semibold">{account.projects.length}</p>
              <div class="mt-3 flex h-2 overflow-hidden rounded-full bg-secondary">
                {
                  statusBreakdown.map((status) => (
                    <span class={status.className} style={`width: ${status.share}%`} title={`${status.label}: ${status.value}`} />
                  ))
                }
              </div>
              <p class="mt-2 text-xs text-muted-foreground">{busiestProject ? `${busiestProject.name} leads traffic` : "No project activity yet"}</p>
            </CardContent>
          </Card>
        </section>

        {
          hasProjects && (
            <section class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)]">
              <Card className="min-w-0">
                <CardHeader>
                  <div class="flex min-w-0 flex-wrap items-start justify-between gap-3">
                    <div>
                      <CardTitle className="flex items-center gap-2">
                        <Activity className="size-4 text-primary" /> Project activity
                      </CardTitle>
                      <p class="mt-1 text-sm text-muted-foreground">Relative 24h traffic by project.</p>
                    </div>
                    <Badge variant="outline">{formatCount(totalEvents)} total</Badge>
                  </div>
                </CardHeader>
                <CardContent className="grid gap-3">
                  {projectActivityBars.map((project) => (
                    <a class="grid gap-2 rounded-md border p-3 transition hover:bg-muted/60" href={`/app/projects/${project.slug}`}>
                      <div class="flex min-w-0 items-center justify-between gap-3">
                        <div class="min-w-0">
                          <p class="truncate font-medium">{project.name}</p>
                          <p class="mt-0.5 truncate font-mono text-xs text-muted-foreground">{project.endpointHost}</p>
                        </div>
                        <p class="shrink-0 text-sm font-semibold">{formatCount(project.eventCount24h)}</p>
                      </div>
                      <div class="h-2 rounded-full bg-secondary">
                        <div class="h-full rounded-full bg-primary" style={`width: ${project.share}%`} />
                      </div>
                    </a>
                  ))}
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle>Status mix</CardTitle>
                </CardHeader>
                <CardContent className="grid gap-4">
                  <div class="flex h-28 items-end gap-2 rounded-md border bg-muted/30 p-3">
                    {statusBreakdown.map((status) => (
                      <div class="grid flex-1 gap-2 text-center">
                        <div class="flex h-20 items-end rounded-sm bg-secondary p-px">
                          <div class={`w-full rounded-sm ${status.className}`} style={`height: ${Math.max(6, status.share)}%`} />
                        </div>
                        <span class="truncate text-xs text-muted-foreground">{status.label}</span>
                      </div>
                    ))}
                  </div>
                  <div class="grid gap-2 text-sm">
                    {statusBreakdown.map((status) => (
                      <div class="flex items-center justify-between gap-3">
                        <span class="text-muted-foreground">{status.label}</span>
                        <span class="font-medium">{status.value}</span>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </section>
          )
        }

        <section class="mt-6">
          <div class="mb-4 flex items-center justify-between gap-3">
            <p class="text-sm text-muted-foreground">{projectCountLabel}</p>
            {
              canCreateProjects && (
                <a
                  class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg bg-primary px-2.5 text-sm font-medium whitespace-nowrap text-primary-foreground transition-all hover:bg-primary/80 focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
                  href="/app/projects/new"
                >
                  <Plus className="size-4" /> New project
                </a>
              )
            }
          </div>

          {
            hasProjects ? (
              <div class="grid gap-4 md:grid-cols-2">
                {account.projects.map((project) => (
                  <Card>
                    <CardHeader>
                      <div class="flex items-start justify-between gap-3">
                        <div>
                          <CardTitle><a href={`/app/projects/${project.slug}`}>{project.name}</a></CardTitle>
                          <p class="mt-1 font-mono text-xs text-muted-foreground">{project.endpointHost}</p>
                        </div>
                        <Badge variant={project.status === "active" ? "default" : "secondary"}>{project.status}</Badge>
                      </div>
                    </CardHeader>
                    <CardContent>
                      <div class="grid grid-cols-3 gap-3 text-sm">
                        <div>
                          <p class="text-xs text-muted-foreground">Environment</p>
                          <p class="font-medium">{environmentLabels[project.environment]}</p>
                        </div>
                        <div>
                          <p class="text-xs text-muted-foreground">24h Events</p>
                          <p class="font-medium">{formatCount(project.eventCount24h)}</p>
                        </div>
                        <div>
                          <p class="text-xs text-muted-foreground">Snippet</p>
                          <p class="font-medium">{project.pixelVersion}</p>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            ) : (
              <div class="flex flex-col items-start gap-3 rounded-md border border-dashed p-5">
                <div>
                  <p class="font-medium">No projects yet</p>
                  <p class="mt-1 text-sm text-muted-foreground">Add a project to get install details, a tracking domain, and an event stream.</p>
                </div>
                {
                  canCreateProjects && (
                    <a
                      class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md bg-primary px-2.5 text-sm font-medium text-primary-foreground transition hover:bg-primary/80"
                      href="/app/projects/new"
                    >
                      <FolderPlus className="size-4" /> Add project
                    </a>
                  )
                }
              </div>
            )
          }
        </section>

        <Card className="mt-6">
          <CardHeader>
            <CardTitle>Recent project activity</CardTitle>
          </CardHeader>
          <CardContent>
            {
              hasProjects ? (
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead>Project</TableHead>
                      <TableHead>Tracking domain</TableHead>
                      <TableHead>Status</TableHead>
                      <TableHead className="text-right">24h Events</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {account.projects.map((project) => (
                      <TableRow>
                        <TableCell>
                          <a class="font-medium hover:underline" href={`/app/projects/${project.slug}`}>{project.name}</a>
                          <p class="text-xs text-muted-foreground">{project.lastEventAt}</p>
                        </TableCell>
                        <TableCell className="font-mono text-xs">{project.endpointHost}</TableCell>
                        <TableCell><Badge variant="outline">{project.status}</Badge></TableCell>
                        <TableCell className="text-right">{formatCount(project.eventCount24h)}</TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              ) : (
                <div class="flex flex-col items-start gap-3 rounded-md border border-dashed p-5">
                  <div>
                    <p class="font-medium">No projects yet</p>
                    <p class="mt-1 text-sm text-muted-foreground">Add a project to get install details, a tracking domain, and an event stream.</p>
                  </div>
                  <a class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md bg-primary px-2.5 text-sm font-medium text-primary-foreground transition hover:bg-primary/80" href="/app/projects/new">
                    <FolderPlus className="size-4" /> Add project
                  </a>
                </div>
              )
            }
          </CardContent>
        </Card>
      </>
    )
  }
</AppLayout>
