---
import { env } from "cloudflare:workers";
import { Activity, Bot, ChevronDown, Copy, Download, ExternalLink, Globe2, KeyRound, Link2, Plus, Radio, RefreshCw, Search, TerminalSquare, UserRound, Webhook } from "lucide-react";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import InstallPanel from "@/components/InstallPanel";
import ProjectShareDialog from "@/components/ProjectShareDialog";
import { SessionFlowExplorer } from "@/components/SessionFlowExplorer";
import { Separator } from "@/components/ui/separator";
import AppLayout from "@/layouts/AppLayout.astro";
import { canUseFeature } from "@/lib/pricing";
import {
  canAdministerAccount,
  canManageProject,
  createDeletionRequest,
  createEnvironmentCredential,
  createPublicVerificationLink,
  createWebhookEndpoint,
  environmentLabels,
  formatCount,
  getProject,
  getViewerAccount,
  hostedEndpointHost,
  projectEnvironmentOptions,
  removeProjectShare,
  saveSitePrivacySettings,
  shareProject,
  updateProjectShare,
  type ProjectShareRole,
} from "@/lib/sarge-demo";

export const prerender = false;

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");
const currentUser = await Astro.locals.currentUser();
const viewerEmails = currentUser?.emailAddresses.map((email) => email.emailAddress).filter(Boolean) ?? [];

const account = await getViewerAccount(userId, env.DATABASE_URL, { viewerEmails });
const project = getProject(account, Astro.params.projectId ?? "");
if (!project) return Astro.redirect("/app");

const requestedEnvironment = Astro.url.searchParams.get("environment");
const selectedEnvironment =
  project.environments.find((environment) => environment.environment === requestedEnvironment) ??
  project.environments.find((environment) => environment.environment === "production") ??
  project.environments[0] ??
  project;
const selectedEnvironmentLabel = environmentLabels[selectedEnvironment.environment];
const environmentOptions = projectEnvironmentOptions.map((environment) => ({
  label: environmentLabels[environment],
  href: environment === "production" ? `/app/projects/${project.siteId}` : `/app/projects/${project.siteId}?environment=${environment}`,
  selected: environment === selectedEnvironment.environment,
}));

const canShareProject = project.ownership === "owned" && canAdministerAccount(account);
const canUseAiReview = canUseFeature(account.planId, "aiReview");
const canUseWebhooks = canUseFeature(account.planId, "webhooks");
const canUseServerEvents = canUseFeature(account.planId, "serverEvents");
const canUsePostbacks = canUseFeature(account.planId, "postbacks");
const canCreateWebhooks = canManageProject(project) && canUseWebhooks;
const canManageCredentials = canManageProject(project) && (canUseServerEvents || canUsePostbacks);
let webhookError = "";
let createdWebhookSecret = "";
let createdWebhookName = "";
let credentialError = "";
let shareError = "";
let shareWarning = "";
let shareSuccess = "";
let createdServerCredentialToken = "";
let createdServerCredentialEndpoint = "";
let createdPostbackCredentialToken = "";
let createdPostbackCredentialEndpoint = "";
let publicVerificationError = "";
let createdPublicVerificationUrl = "";
let createdPublicVerificationExpiresAt: Date | null = null;
let sitePrivacySettingsError = "";
let sitePrivacySettingsSuccess = "";
let siteDeletionRequestError = "";
let siteDeletionRequestSuccess = "";
let webhookValues = {
  name: "",
  url: "",
  eventNames: "",
};
const runtimeEnv = env as unknown as Record<string, string | undefined>;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "share-project") {
    if (!canShareProject) {
      shareError = "Only project owners can share projects.";
    } else {
      const result = await shareProject(
        userId,
        env.DATABASE_URL,
        project.siteId,
        {
          email: String(formData.get("email") ?? ""),
          role: String(formData.get("role") ?? "view") as ProjectShareRole,
        },
        {
          emailSender: env.EMAIL,
          emailFrom: runtimeEnv.SARGE_EMAIL_FROM,
          appUrl: `${Astro.url.origin}/app`,
        },
      );

      if (result.success) {
        project.shares = [result.share, ...project.shares.filter((share) => share.id !== result.share.id)];
        shareWarning = result.warning ?? "";
        shareSuccess = result.warning ? "" : `${result.share.email} can now ${result.share.role === "edit" ? "edit" : "view"} this project.`;
      } else {
        shareError = result.error;
      }
    }
  }

  if (intent === "update-project-share") {
    if (!canShareProject) {
      shareError = "Only project owners can update project shares.";
    } else {
      const result = await updateProjectShare(
        userId,
        env.DATABASE_URL,
        String(formData.get("shareId") ?? ""),
        String(formData.get("role") ?? "view") as ProjectShareRole,
        {
          emailSender: env.EMAIL,
          emailFrom: runtimeEnv.SARGE_EMAIL_FROM,
          appUrl: `${Astro.url.origin}/app`,
        },
      );

      if (result.success) {
        project.shares = project.shares.map((share) => (share.id === result.share.id ? result.share : share));
        shareSuccess = `${result.share.email} now has ${result.share.role} access.`;
      } else {
        shareError = result.error;
      }
    }
  }

  if (intent === "remove-project-share") {
    if (!canShareProject) {
      shareError = "Only project owners can remove project shares.";
    } else {
      const shareId = String(formData.get("shareId") ?? "");
      const result = await removeProjectShare(userId, env.DATABASE_URL, shareId, {
        emailSender: env.EMAIL,
        emailFrom: runtimeEnv.SARGE_EMAIL_FROM,
        appUrl: `${Astro.url.origin}/app`,
      });

      if (result.success) {
        project.shares = project.shares.filter((share) => share.id !== shareId);
        shareSuccess = "Project access was removed.";
      } else {
        shareError = result.error;
      }
    }
  }

  if (intent === "create-webhook") {
    webhookValues = {
      name: String(formData.get("webhookName") ?? ""),
      url: String(formData.get("webhookUrl") ?? ""),
      eventNames: String(formData.get("webhookEventNames") ?? ""),
    };

    if (!canUseWebhooks) {
      webhookError = "Webhooks are available on Starter and higher.";
    } else if (!canCreateWebhooks) {
      webhookError = "Edit access is required to create webhooks.";
    } else {
      const result = await createWebhookEndpoint(userId, env.DATABASE_URL, selectedEnvironment.id, webhookValues);

      if (result.success) {
        selectedEnvironment.webhookEndpoints = [result.webhook, ...selectedEnvironment.webhookEndpoints];
        createdWebhookSecret = result.signingSecret;
        createdWebhookName = result.webhook.name;
        webhookValues = { name: "", url: "", eventNames: "" };
      } else {
        webhookError = result.error;
      }
    }
  }

  if (intent === "rotate-server-credential" || intent === "rotate-postback-token") {
    const kind = intent === "rotate-server-credential" ? "server" : "postback";
    const canRotateCredential = canManageProject(project) && (kind === "server" ? canUseServerEvents : canUsePostbacks);

    if (kind === "server" && !canUseServerEvents) {
      credentialError = "Upgrade to create server event secrets.";
    } else if (kind === "postback" && !canUsePostbacks) {
      credentialError = "Postbacks are available on Starter and higher.";
    } else if (!canRotateCredential) {
      credentialError = "Edit access is required to manage server-side credentials.";
    } else {
      const result = await createEnvironmentCredential(userId, env.DATABASE_URL, selectedEnvironment.id, kind);

      if (result.success) {
        if (result.kind === "server") {
          createdServerCredentialToken = result.token;
          createdServerCredentialEndpoint = result.endpoint;
          selectedEnvironment.serverEventSecretConfigured = true;
        } else {
          createdPostbackCredentialToken = result.token;
          createdPostbackCredentialEndpoint = result.endpoint;
          selectedEnvironment.postbackTokenConfigured = true;
        }
      } else {
        credentialError = result.error;
      }
    }
  }

  if (intent === "create-public-verification-link") {
    if (!canManageProject(project)) {
      publicVerificationError = "Edit access is required to create verification links.";
    } else {
      const result = await createPublicVerificationLink(userId, env.DATABASE_URL, selectedEnvironment.id, Astro.url.origin);
      if (result.success) {
        createdPublicVerificationUrl = result.url;
        createdPublicVerificationExpiresAt = result.expiresAt;
      } else {
        publicVerificationError = result.error;
      }
    }
  }

  if (intent === "save-site-privacy-settings") {
    if (project.ownership !== "owned") {
      sitePrivacySettingsError = "Only project owners can manage data controls.";
    } else {
      const result = await saveSitePrivacySettings(userId, env.DATABASE_URL, project.siteId, {
        piiRedactionEnabled: formData.get("piiRedactionEnabled") === "on",
        propertyPolicyMode: String(formData.get("propertyPolicyMode") ?? "blocklist"),
        blockedPropertyKeys: String(formData.get("blockedPropertyKeys") ?? ""),
        allowedPropertyKeys: String(formData.get("allowedPropertyKeys") ?? ""),
        customRedactionKeys: String(formData.get("customRedactionKeys") ?? ""),
        customRedactionPatterns: String(formData.get("customRedactionPatterns") ?? ""),
      });

      if (result.success) {
        project.privacySettings = result.settings;
        sitePrivacySettingsSuccess = "Project data controls were saved.";
      } else {
        sitePrivacySettingsError = result.error;
      }
    }
  }

  if (intent === "request-site-deletion") {
    if (project.ownership !== "owned") {
      siteDeletionRequestError = "Only project owners can request deletion.";
    } else {
      const result = await createDeletionRequest(userId, env.DATABASE_URL, {
        scope: "site",
        targetSiteId: project.siteId,
        confirmation: String(formData.get("deleteConfirmation") ?? ""),
      });

      if (result.success) siteDeletionRequestSuccess = "Site deletion request was queued.";
      else siteDeletionRequestError = result.error;
    }
  }
}

const snippet = `<script>
  window._sarge = { queue: [["track", "page.view"]] };
</script>
<script async src="${selectedEnvironment.pixelUrl}"></script>`;
const publicVerifyUrlTemplate = `/verify/${selectedEnvironment.id}?key={temporaryVerificationKey}`;
const publicVerifyAbsoluteUrlTemplate = `https://sargetrack.app${publicVerifyUrlTemplate}`;
const debugStreamEndpoint = `/api/project-events/${selectedEnvironment.id}`;
const llmInstallPrompt = `Add Sarge tracking for ${project.name} ${selectedEnvironmentLabel}.

Read these docs first:
- https://sargetrack.app/llms.txt
- https://sargetrack.app/docs/install.md
- https://sargetrack.app/docs/events.md

Install this pixel snippet as early as possible in the page:

${snippet}

Then emit window.sarge("track", "event.name", properties) for page, product, cart, checkout, and purchase actions. Keep existing Meta, Google, or analytics pixels in place. After wiring, create a 30-minute verification link in Sarge and open ${publicVerifyAbsoluteUrlTemplate} to verify the expected events appear in the public Sarge event stream.`;
const endpointHealthUrl = selectedEnvironment.endpointHealthUrl;
const pixelUrl = selectedEnvironment.pixelUrl;
const customDomain = project.customDomain;
const trackingDomain = resolveSargeTrackingDomain(customDomain);
const trackedSiteDomain = resolveTrackedSiteDomain(customDomain);
const displayedTrackingDomain = trackingDomain;
const customDomainHeadingLink = {
  label: customDomain,
  href: `https://${displayedTrackingDomain}`,
};
const customDomainPixelUrl = `https://${trackingDomain}/pixel.js?env=${encodeURIComponent(selectedEnvironment.id)}`;
const customDomainPixelDownloadUrl = buildCustomPixelDownloadUrl(pixelUrl, trackingDomain);
const customDomainSnippet = `<script>
  window._sarge = { queue: [["track", "page.view"]] };
</script>
<script async src="${customDomainPixelUrl}"></script>`;
const serverEventEndpoint = `https://${hostedEndpointHost}/v2/server/events`;
const postbackEndpointTemplate = `https://${hostedEndpointHost}/v2/postback/${selectedEnvironment.id}/{postbackToken}`;
const attributionWindowDays = selectedEnvironment.attributionTtlDays;
const affiliateCaptureUrl = `https://${trackedSiteDomain}/?sarge_ref=summer-campaign&sarge_aff=partner-42`;
const createdServerCredentialCurl = createdServerCredentialToken
  ? `curl -X POST "${serverEventEndpoint}" \\
  -H "authorization: Bearer ${createdServerCredentialToken}" \\
  -H "content-type: application/json" \\
  -d '{
    "siteId": "${selectedEnvironment.id}",
    "name": "purchase.completed",
    "eventId": "order_123",
    "userId": "customer_123",
    "properties": {
      "order_id": "order_123",
      "value": 129.99,
      "currency": "USD"
    }
  }'`
  : "";

const recentEvents = selectedEnvironment.recentEvents.slice(0, 12);
const flowEvents = selectedEnvironment.recentEvents.slice(0, 80);
const flowEventsEndpoint = `${debugStreamEndpoint}?limit=80`;
const eventHosts = selectedEnvironment.eventHosts;
const webhookEndpoints = selectedEnvironment.webhookEndpoints;
const projectTesterUserId = buildProjectTesterUserId(selectedEnvironment.id, userId);
const recentUserOptions = buildRecentUserOptions(selectedEnvironment.recentEvents, projectTesterUserId);
const impersonationConsoleSnippet = buildImpersonationConsoleSnippet(projectTesterUserId);
const isAiReviewEnabled = selectedEnvironment.environment === "production" && canUseAiReview;
const diagnostics = isAiReviewEnabled ? selectedEnvironment.diagnostics : [];
const hasSelectedEnvironmentEvents =
  selectedEnvironment.eventCount24h > 0 || selectedEnvironment.recentEvents.length > 0;
const pixelInstallStatus = getPixelInstallStatus(selectedEnvironment.status, hasSelectedEnvironmentEvents);
const endpointHealth = pixelInstallStatus === "active" ? "healthy" : "pending";
const isPixelActive = pixelInstallStatus === "active";
const criticalFindings = diagnostics.filter((finding) => finding.severity === "critical").length;
const warningFindings = diagnostics.filter((finding) => finding.severity === "warning").length;
const diagnosticRunLabel = selectedEnvironment.diagnosticRunAt ? new Date(selectedEnvironment.diagnosticRunAt).toLocaleString() : "Pending first scheduled run";
const eventTypeMix = selectedEnvironment.eventMix24h;
const eventVolumeDelta = buildMetricDelta(selectedEnvironment.eventCount24h, selectedEnvironment.previousEventCount24h);
const recentSessionDelta = buildMetricDelta(selectedEnvironment.sessionCount24h, selectedEnvironment.previousSessionCount24h);
const recentUserDelta = buildMetricDelta(selectedEnvironment.userCount24h, selectedEnvironment.previousUserCount24h);
const weeklyTrafficChart = buildTrafficTrendChart(selectedEnvironment.trafficTrend7d);
const projectShareLimit = account.plan.limits.projectShares;
const projectShareCount = project.shares.length;
const canManageProjectData = project.ownership === "owned";
const projectPrivacySettings = project.privacySettings;
const formatSettingsList = (values: string[]) => values.join(", ");
const severityVariant = (severity: string) => {
  if (severity === "critical") return "destructive";
  if (severity === "warning") return "secondary";
  return "outline";
};
const severityClass = (severity: string) => {
  if (severity === "critical") return "border-destructive/30 bg-destructive/5";
  if (severity === "warning") return "border-amber-500/30 bg-amber-500/5";
  return "border-border bg-card";
};
const isWatchdogEvent = (name: string) =>
  name === "meta.pixel.fire" || name === "google.tag.fire" || name === "data_layer.push";

function isTestTraffic(properties: Record<string, unknown>) {
  return properties.sarge_test === true;
}

const formatEventTime = (value: string) =>
  new Intl.DateTimeFormat("en-US", {
    hour: "numeric",
    minute: "2-digit",
    second: "2-digit",
  }).format(new Date(value));

const formatEventPayload = (value: Record<string, unknown>) => JSON.stringify(value, null, 2);

function buildMetricDelta(currentValue: number, previousValue: number) {
  if (previousValue === 0) {
    return {
      label: currentValue > 0 ? "new" : "0%",
      tone: currentValue > 0 ? "up" : "neutral",
      significant: currentValue > 0,
      currentValue,
      previousValue,
    };
  }

  const percent = Math.round(((currentValue - previousValue) / previousValue) * 100);
  const significant = Math.abs(percent) >= 15;
  return {
    label: `${percent > 0 ? "+" : ""}${percent}%`,
    tone: !significant ? "neutral" : percent > 0 ? "up" : percent < 0 ? "down" : "neutral",
    significant,
    currentValue,
    previousValue,
  };
}

function renderMetricDelta(delta: ReturnType<typeof buildMetricDelta>) {
  return delta.label;
}

function metricDeltaClass(delta: ReturnType<typeof buildMetricDelta>) {
  if (delta.tone === "up") return "border-emerald-500/30 bg-emerald-500/10 text-emerald-300";
  if (delta.tone === "down") return "border-rose-500/30 bg-rose-500/10 text-rose-300";
  return "border-border bg-background text-muted-foreground";
}

function formatMetricDeltaTitle(delta: ReturnType<typeof buildMetricDelta>) {
  return `${formatCount(delta.currentValue)} in the last 24h vs ${formatCount(delta.previousValue)} in the previous 24h`;
}

function buildTrafficTrendChart(points: typeof selectedEnvironment.trafficTrend7d) {
  const width = 460;
  const height = 148;
  const paddingLeft = 44;
  const paddingRight = 12;
  const paddingTop = 16;
  const paddingBottom = 28;
  const plotHeight = height - paddingTop - paddingBottom;
  const maxValue = Math.max(1, ...points.map((point) => point.value));
  const xStep = points.length > 1 ? (width - paddingLeft - paddingRight) / (points.length - 1) : 0;
  const plotEndX = width - paddingRight;
  const yAxisValues = maxValue > 1 ? [maxValue, Math.round(maxValue / 2), 0] : [maxValue, 0];
  const yAxisLabels = yAxisValues.map((value) => ({
    value,
    y: Number((paddingTop + plotHeight - (value / maxValue) * plotHeight).toFixed(2)),
  }));
  const coordinates = points.map((point, index) => {
    const x = paddingLeft + index * xStep;
    const y = paddingTop + plotHeight - (point.value / maxValue) * plotHeight;
    const tooltipY = y < paddingTop + 30 ? y + 46 : y - 10;
    return {
      ...point,
      x: Number(x.toFixed(2)),
      y: Number(y.toFixed(2)),
      hoverX: Number((x - xStep / 2).toFixed(2)),
      hoverWidth: Number((points.length > 1 ? xStep : plotEndX - paddingLeft).toFixed(2)),
      tooltipX: Number(Math.min(plotEndX - 48, Math.max(paddingLeft + 48, x)).toFixed(2)),
      tooltipY: Number(tooltipY.toFixed(2)),
    };
  });
  const linePoints = coordinates.map((point) => `${point.x},${point.y}`).join(" ");
  const baselineY = height - paddingBottom;
  const areaPoints = coordinates.length > 0
    ? `${paddingLeft},${baselineY} ${linePoints} ${plotEndX},${baselineY}`
    : "";

  return {
    width,
    height,
    paddingLeft,
    paddingTop,
    plotHeight,
    plotEndX,
    baselineY,
    yAxisLabels,
    maxValue,
    coordinates,
    linePoints,
    areaPoints,
    lastPoint: coordinates.at(-1),
  };
}

function buildProjectTesterUserId(projectId: string, viewerUserId: string) {
  return `sarge_test_${hashId(`${projectId}:${viewerUserId}`)}`;
}

function buildRecentUserOptions(events: typeof selectedEnvironment.recentEvents, currentUserId: string) {
  const usersById = new Map<string, { userId: string; eventCount: number; lastEventAt: string }>();

  for (const event of events) {
    if (!event.userId || event.userId === currentUserId || isTestTraffic(event.properties)) continue;

    const existing = usersById.get(event.userId);
    if (!existing) {
      usersById.set(event.userId, {
        userId: event.userId,
        eventCount: 1,
        lastEventAt: event.occurredAt,
      });
      continue;
    }

    existing.eventCount += 1;
    if (Date.parse(event.occurredAt) > Date.parse(existing.lastEventAt)) {
      existing.lastEventAt = event.occurredAt;
    }
  }

  return Array.from(usersById.values())
    .sort((left, right) => Date.parse(right.lastEventAt) - Date.parse(left.lastEventAt))
    .slice(0, 8);
}

function buildImpersonationConsoleSnippet(userId: string) {
  return `impersonate('${escapeConsoleString(userId)}');`;
}

function escapeConsoleString(value: string) {
  return value.replace(/\\/g, "\\\\").replace(/'/g, "\\'");
}

function getPixelInstallStatus(configStatus: typeof selectedEnvironment.status, hasEvents: boolean) {
  if (configStatus !== "active") return configStatus;
  return hasEvents ? "active" : "pending";
}

function hashId(value: string) {
  let hash = 5381;
  for (let index = 0; index < value.length; index += 1) {
    hash = (hash * 33) ^ value.charCodeAt(index);
  }

  return (hash >>> 0).toString(36).padStart(6, "0");
}

function buildCustomPixelDownloadUrl(value: string, endpointHost: string) {
  const url = new URL(value);
  url.searchParams.set("download", "1");
  url.searchParams.set("endpointHost", endpointHost);
  return url.toString();
}

function resolveSargeTrackingDomain(value: string) {
  const hostname = value.toLowerCase().replace(/^https?:\/\//, "").replace(/\/.*$/, "").replace(/^www\./, "");
  return hostname.startsWith("sarge.") ? hostname : `sarge.${hostname}`;
}

function resolveTrackedSiteDomain(value: string) {
  const hostname = value.toLowerCase().replace(/^https?:\/\//, "").replace(/\/.*$/, "").replace(/^www\./, "");
  return hostname.startsWith("sarge.") ? hostname.slice("sarge.".length) : hostname;
}
