<AppLayout
  account={account}
  title={`${project.name} | Sarge`}
  eyebrow="Project"
  heading={project.name}
  headingLink={customDomainHeadingLink}
  description="Copy install snippets, check project health, and watch for media/debug events."
  active="overview"
  breadcrumbs={[
    { label: "Overview", href: "/app" },
    { label: project.name },
  ]}
>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3 rounded-lg border bg-card p-2">
    <div class="inline-flex rounded-md bg-muted p-1">
      {
        environmentOptions.map((environmentOption) => (
          <a
            class:list={[
              "inline-flex h-7 items-center rounded-md px-3 text-sm font-medium transition-colors",
              environmentOption.selected
                ? "bg-background text-foreground shadow-sm"
                : "text-muted-foreground hover:bg-background/70 hover:text-foreground",
            ]}
            href={environmentOption.href}
            aria-current={environmentOption.selected ? "page" : undefined}
          >
            {environmentOption.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center gap-2">
      <p class="text-xs text-muted-foreground">Viewing {selectedEnvironmentLabel} for this project.</p>
      {canShareProject && (
        <ProjectShareDialog
          projectName={project.name}
          shares={project.shares}
          shareLimit={projectShareLimit}
          shareCount={projectShareCount}
          error={shareError}
          warning={shareWarning}
          success={shareSuccess}
          client:load
        />
      )}
    </div>
  </div>

  <section class="mb-4 grid gap-4 lg:grid-cols-[minmax(0,1.1fr)_minmax(300px,0.9fr)]" data-project-pulse>
    <Card className="min-w-0">
      <CardHeader>
        <div class="flex min-w-0 flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Project pulse</p>
            <CardTitle className="mt-1 flex items-center gap-2">
              <Activity className="size-4 text-primary" /> Last 24 hours
            </CardTitle>
          </div>
          <div class="text-right">
            <div class="flex flex-wrap items-center justify-end gap-2">
              <span
                class:list={[
                  "inline-flex items-center rounded-md border px-1.5 py-0.5 text-xs font-medium",
                  metricDeltaClass(eventVolumeDelta),
                ]}
                title={formatMetricDeltaTitle(eventVolumeDelta)}
              >
                {renderMetricDelta(eventVolumeDelta)}
              </span>
              <p class="text-2xl font-semibold leading-none">{formatCount(selectedEnvironment.eventCount24h)}</p>
            </div>
            <p class="mt-1 text-xs text-muted-foreground">Events received</p>
            <p class="mt-1 text-xs text-muted-foreground">{selectedEnvironment.lastEventAt}</p>
          </div>
        </div>
      </CardHeader>
      <CardContent>
        <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_160px]">
          <div class="rounded-md border bg-muted/20 p-4" data-project-traffic-trend>
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Weekly traffic</p>
                <p class="mt-1 text-sm text-muted-foreground">Events received by day</p>
              </div>
              <p class="text-xs text-muted-foreground">Peak {formatCount(weeklyTrafficChart.maxValue)}</p>
            </div>
            <div class="mt-4">
              <svg
                class="h-auto w-full overflow-visible"
                width={weeklyTrafficChart.width}
                height={weeklyTrafficChart.height}
                viewBox={`0 0 ${weeklyTrafficChart.width} ${weeklyTrafficChart.height}`}
                role="img"
                aria-label="Events received over the last seven days"
              >
                <defs>
                  <linearGradient id="weeklyTrafficFill" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="currentColor" stop-opacity="0.22" />
                    <stop offset="100%" stop-color="currentColor" stop-opacity="0.02" />
                  </linearGradient>
                </defs>
                <g class="text-muted-foreground">
                  {
                    weeklyTrafficChart.yAxisLabels.map((label) => (
                      <text x="0" y={label.y + 4} fill="currentColor" font-size="10">
                        {formatCount(label.value)}
                      </text>
                    ))
                  }
                </g>
                <g class="text-border">
                  {
                    weeklyTrafficChart.yAxisLabels.map((label, index) => (
                      <line
                        x1={weeklyTrafficChart.paddingLeft}
                        x2={weeklyTrafficChart.plotEndX}
                        y1={label.y}
                        y2={label.y}
                        stroke="currentColor"
                        stroke-width="1"
                        stroke-dasharray={index === weeklyTrafficChart.yAxisLabels.length - 1 ? undefined : "3 5"}
                      />
                    ))
                  }
                </g>
                <polygon class="text-primary" points={weeklyTrafficChart.areaPoints} fill="url(#weeklyTrafficFill)" />
                <polyline
                  points={weeklyTrafficChart.linePoints}
                  fill="none"
                  stroke="var(--primary)"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  vector-effect="non-scaling-stroke"
                />
                {
                  weeklyTrafficChart.coordinates.map((point) => (
                    <g
                      class="group outline-none"
                      tabindex="0"
                      data-project-traffic-point
                      aria-label={`${point.label}: ${formatCount(point.value)} events`}
                    >
                      <rect
                        x={point.hoverX}
                        y={weeklyTrafficChart.paddingTop}
                        width={point.hoverWidth}
                        height={weeklyTrafficChart.plotHeight}
                        fill="transparent"
                        class="cursor-crosshair"
                      />
                      <line
                        class="opacity-0 transition-opacity group-focus:opacity-100 group-hover:opacity-100"
                        x1={point.x}
                        x2={point.x}
                        y1={weeklyTrafficChart.paddingTop}
                        y2={weeklyTrafficChart.baselineY}
                        stroke="var(--primary)"
                        stroke-opacity="0.55"
                        stroke-width="1"
                        stroke-dasharray="3 4"
                        vector-effect="non-scaling-stroke"
                      />
                      <circle
                        cx={point.x}
                        cy={point.y}
                        r="3.5"
                        fill="var(--background)"
                        stroke="var(--primary)"
                        stroke-width="2"
                        vector-effect="non-scaling-stroke"
                      />
                      <g
                        class="pointer-events-none opacity-0 transition-opacity group-focus:opacity-100 group-hover:opacity-100"
                        transform={`translate(${point.tooltipX} ${point.tooltipY})`}
                      >
                        <rect x="-48" y="-28" width="96" height="24" rx="5" fill="var(--popover)" stroke="var(--border)" />
                        <text text-anchor="middle" y="-12" fill="var(--popover-foreground)" font-size="11" font-weight="600">
                          {formatCount(point.value)} events
                        </text>
                      </g>
                      <title>{point.label}: {formatCount(point.value)} events</title>
                    </g>
                  ))
                }
                {
                  weeklyTrafficChart.lastPoint && (
                    <circle
                      cx={weeklyTrafficChart.lastPoint.x}
                      cy={weeklyTrafficChart.lastPoint.y}
                      r="5"
                      fill="var(--primary)"
                      stroke="var(--background)"
                      stroke-width="2"
                      vector-effect="non-scaling-stroke"
                    />
                  )
                }
              </svg>
              <div class="mt-1 grid grid-cols-7 gap-1 text-center text-[11px] text-muted-foreground">
                {weeklyTrafficChart.coordinates.map((point) => <span>{point.label}</span>)}
              </div>
            </div>
          </div>
          <div class="grid gap-3 text-sm">
            <div class="rounded-md border p-3">
