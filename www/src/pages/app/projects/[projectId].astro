  {
    canManageProjectData && (
      <section class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1fr)_320px]" data-project-data-controls>
        <Card>
          <CardHeader>
            <CardTitle>Data controls</CardTitle>
            <p class="text-sm text-muted-foreground">Project-level hosted ingestion controls. These override workspace defaults for this project.</p>
          </CardHeader>
          <CardContent className="grid gap-4">
            {sitePrivacySettingsError && (
              <Alert variant="destructive">
                <AlertTitle>Data controls were not saved</AlertTitle>
                <AlertDescription>{sitePrivacySettingsError}</AlertDescription>
              </Alert>
            )}
            {sitePrivacySettingsSuccess && (
              <Alert>
                <AlertTitle>Data controls saved</AlertTitle>
                <AlertDescription>{sitePrivacySettingsSuccess}</AlertDescription>
              </Alert>
            )}
            <form method="post" class="grid gap-4">
              <input type="hidden" name="intent" value="save-site-privacy-settings" />
              <label class="flex items-center gap-3 rounded-md border bg-muted/30 p-3 text-sm">
                <input class="size-4 accent-primary" type="checkbox" name="piiRedactionEnabled" checked={projectPrivacySettings.piiRedactionEnabled} />
                <span><span class="font-medium">PII redaction</span><span class="block text-xs text-muted-foreground">Redact common emails, phones, secrets, addresses, IPs, and card-like values before storage.</span></span>
              </label>
              <div class="grid gap-2">
                <Label htmlFor="projectPropertyPolicyMode">Property policy</Label>
                <select id="projectPropertyPolicyMode" name="propertyPolicyMode" class="h-9 rounded-md border bg-background px-3 text-sm">
                  <option value="blocklist" selected={projectPrivacySettings.propertyPolicyMode === "blocklist"}>Blocklist default</option>
                  <option value="allowlist" selected={projectPrivacySettings.propertyPolicyMode === "allowlist"}>Allowlist mode</option>
                </select>
              </div>
              <div class="grid gap-2 md:grid-cols-2">
                <div class="grid gap-2">
                  <Label htmlFor="projectBlockedPropertyKeys">Blocked property keys</Label>
                  <Input id="projectBlockedPropertyKeys" name="blockedPropertyKeys" value={formatSettingsList(projectPrivacySettings.blockedPropertyKeys)} placeholder="email, phone, internal_note" />
                </div>
                <div class="grid gap-2">
                  <Label htmlFor="projectAllowedPropertyKeys">Allowed property keys</Label>
                  <Input id="projectAllowedPropertyKeys" name="allowedPropertyKeys" value={formatSettingsList(projectPrivacySettings.allowedPropertyKeys)} placeholder="order_id, value, currency" />
                </div>
                <div class="grid gap-2">
                  <Label htmlFor="projectCustomRedactionKeys">Custom redaction keys</Label>
                  <Input id="projectCustomRedactionKeys" name="customRedactionKeys" value={formatSettingsList(projectPrivacySettings.customRedactionKeys)} placeholder="coupon_code, customer_email" />
                </div>
                <div class="grid gap-2">
                  <Label htmlFor="projectCustomRedactionPatterns">Custom redaction patterns</Label>
                  <Input id="projectCustomRedactionPatterns" name="customRedactionPatterns" value={formatSettingsList(projectPrivacySettings.customRedactionPatterns)} placeholder="vip-[0-9]+" />
                </div>
              </div>
              <div>
                <Button type="submit">Save project controls</Button>
              </div>
            </form>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Request site deletion</CardTitle>
            <p class="text-sm text-muted-foreground">Queues deletion of this project's events, environments, diagnostics, webhooks, shares, and settings.</p>
          </CardHeader>
          <CardContent className="grid gap-4">
            {siteDeletionRequestError && (
              <Alert variant="destructive">
                <AlertTitle>Deletion was not queued</AlertTitle>
                <AlertDescription>{siteDeletionRequestError}</AlertDescription>
              </Alert>
            )}
            {siteDeletionRequestSuccess && (
              <Alert>
                <AlertTitle>Deletion queued</AlertTitle>
                <AlertDescription>{siteDeletionRequestSuccess}</AlertDescription>
              </Alert>
            )}
            <form method="post" class="grid gap-3">
              <input type="hidden" name="intent" value="request-site-deletion" />
              <div class="grid gap-2">
                <Label htmlFor="siteDeleteConfirmation">Type DELETE to confirm</Label>
                <Input id="siteDeleteConfirmation" name="deleteConfirmation" autocomplete="off" />
              </div>
              <Button type="submit" variant="outline">Request site deletion</Button>
            </form>
          </CardContent>
        </Card>
      </section>
    )
  }

  <script>
    document.querySelectorAll<HTMLButtonElement>("[data-copy-snippet]").forEach((button) => {
      button.addEventListener("click", async () => {
        const snippet = button.dataset.snippet;
        if (!snippet) return;

        try {
          await navigator.clipboard.writeText(snippet);
          const label = button.querySelector("[data-copy-label]");
          const originalText = label?.textContent ?? "Copy snippet";
          if (label) label.textContent = "Copied";
          window.setTimeout(() => {
            if (label) label.textContent = originalText;
          }, 1600);
        } catch {
          const label = button.querySelector("[data-copy-label]");
          if (label) label.textContent = "Copy failed";
        }
      });
    });

    document.addEventListener("click", (event) => {
      const openButton = (event.target as Element | null)?.closest<HTMLButtonElement>("[data-open-event]");
      if (openButton) {
        const dialog = document.getElementById(openButton.dataset.eventDialog ?? "");
        if (dialog instanceof HTMLDialogElement && !dialog.open) dialog.showModal();
        return;
      }

      const closeButton = (event.target as Element | null)?.closest<HTMLButtonElement>("[data-close-event]");
      if (closeButton) closeButton.closest("dialog")?.close();
    });

    document.querySelectorAll<HTMLButtonElement>("[data-copy-prompt]").forEach((button) => {
      button.addEventListener("click", async () => {
        const prompt = button.dataset.prompt;
        if (!prompt) return;

        const label = button.querySelector("[data-prompt-label]");
        try {
          await navigator.clipboard.writeText(prompt);
          const originalText = label?.textContent ?? "Copy prompt";
          if (label) label.textContent = "Copied";
          window.setTimeout(() => {
            if (label) label.textContent = originalText;
          }, 1600);
        } catch {
          if (label) label.textContent = "Copy failed";
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-copy-webhook-secret]").forEach((button) => {
      button.addEventListener("click", async () => {
        const secret = button.dataset.secret;
        if (!secret) return;

        const label = button.querySelector("[data-webhook-secret-label]");
        try {
          await navigator.clipboard.writeText(secret);
          const originalText = label?.textContent ?? "Copy";
          if (label) label.textContent = "Copied";
          window.setTimeout(() => {
            if (label) label.textContent = originalText;
          }, 1600);
        } catch {
          if (label) label.textContent = "Copy failed";
        }
      });
    });

    const escapeImpersonationUserId = (value: string) => value.replace(/\\/g, "\\\\").replace(/'/g, "\\'");
    const buildImpersonationCode = (userId: string) => `impersonate('${escapeImpersonationUserId(userId)}');`;

    const copyTextWithLabel = async (text: string, label: Element | null, fallback: string) => {
      try {
        await navigator.clipboard.writeText(text);
        const originalText = label?.textContent ?? fallback;
        if (label) label.textContent = "Copied";
        window.setTimeout(() => {
          if (label) label.textContent = originalText;
        }, 1600);
      } catch {
        if (label) label.textContent = "Copy failed";
      }
    };

    document.querySelectorAll<HTMLButtonElement>("[data-copy-credential]").forEach((button) => {
      button.addEventListener("click", async () => {
        const credential = button.dataset.credential;
        if (!credential) return;

        await copyTextWithLabel(credential, button.querySelector("[data-credential-label]"), "Copy");
      });
    });

    document.querySelectorAll<HTMLElement>("[data-test-impersonation-card]").forEach((panel) => {
      const input = panel.querySelector<HTMLInputElement>("[data-impersonation-user-input]");
      const code = panel.querySelector<HTMLElement>("[data-impersonation-code]");
      if (!input || !code) return;

      const updateImpersonationCode = () => {
        code.textContent = buildImpersonationCode(input.value.trim());
      };

      input.addEventListener("input", updateImpersonationCode);

      panel.querySelectorAll<HTMLButtonElement>("[data-recent-impersonation-user]").forEach((button) => {
        button.addEventListener("click", () => {
          input.value = button.dataset.userId ?? "";
          updateImpersonationCode();
          input.focus();
        });
      });

      panel.querySelector<HTMLButtonElement>("[data-copy-tester-id]")?.addEventListener("click", async (event) => {
        const button = event.currentTarget;
        const testerId = button.dataset.testerId;
        if (!testerId) return;
        await copyTextWithLabel(testerId, button.querySelector("[data-copy-tester-id-label]"), "Copy");
      });

      panel.querySelector<HTMLButtonElement>("[data-copy-impersonation-code]")?.addEventListener("click", async (event) => {
        updateImpersonationCode();
        const button = event.currentTarget;
        await copyTextWithLabel(code.textContent ?? "", button.querySelector("[data-copy-impersonation-code-label]"), "Copy code");
      });
    });

    type LiveDebugEvent = {
      id: string;
      name: string;
      occurredAt: string;
      receivedAt: string;
      sessionId: string;
      userId: string;
      url?: string;
      ref?: string;
      affiliate?: string;
      title?: string;
      properties: Record<string, unknown>;
    };

    const isWatchdogDebugEvent = (name: string) =>
      name === "meta.pixel.fire" || name === "google.tag.fire" || name === "data_layer.push";
    const isTestDebugEvent = (event: LiveDebugEvent) => event.properties?.sarge_test === true;
    const formatDebugEventTime = (value: string) =>
      new Intl.DateTimeFormat("en-US", {
        hour: "numeric",
        minute: "2-digit",
        second: "2-digit",
      }).format(new Date(value));
    const escapeDebugHtml = (value: unknown) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    const renderDebugEvents = (events: LiveDebugEvent[]) => {
      if (events.length === 0) {
        return `<div class="rounded-md border border-dashed p-6 text-sm text-muted-foreground">
          No live events yet. Open the sample shop and click around to populate this stream.
        </div>`;
      }

      return events
        .map((event) => {
          const dialogId = `event-${event.id}`;
          const pageLabel = event.title ?? event.url ?? "Untitled event";
          const properties = JSON.stringify(event.properties ?? {}, null, 2);
          const iconClass = isWatchdogDebugEvent(event.name) ? "text-cyan-400" : "text-primary";

          return `<div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 rounded-md border p-3">
              <span class="size-4 font-mono text-xs ${iconClass}">[]</span>
              <div class="min-w-0">
                <div class="flex min-w-0 flex-wrap items-center gap-2">
                  <p class="font-mono text-sm">${escapeDebugHtml(event.name)}</p>
                  ${isTestDebugEvent(event) ? `<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium">Test</span>` : ""}
                </div>
                <p class="truncate text-xs text-muted-foreground">
                  ${escapeDebugHtml(pageLabel)} · ${escapeDebugHtml(formatDebugEventTime(event.occurredAt))}
                </p>
              </div>
              <button
                class="inline-flex h-7 items-center justify-center gap-1 rounded-md border px-2 text-xs font-medium hover:bg-muted"
                type="button"
                data-open-event
                data-event-dialog="${escapeDebugHtml(dialogId)}"
              >
                Details
              </button>
            </div>
            <dialog id="${escapeDebugHtml(dialogId)}" class="w-[min(720px,calc(100vw-2rem))] rounded-lg border bg-card p-0 text-card-foreground shadow-xl backdrop:bg-black/20">
              <div class="border-b p-4">
                <div class="flex min-w-0 flex-wrap items-center gap-2">
                  <p class="font-mono text-sm">${escapeDebugHtml(event.name)}</p>
                  ${isTestDebugEvent(event) ? `<span class="inline-flex items-center justify-center rounded-md border px-2 py-0.5 text-xs font-medium">Test</span>` : ""}
                </div>
                <p class="mt-1 text-xs text-muted-foreground">${escapeDebugHtml(event.url ?? "No URL recorded")}</p>
              </div>
              <div class="grid gap-4 p-4 text-sm">
                <div class="grid gap-3 sm:grid-cols-2">
                  <div>
                    <p class="text-xs text-muted-foreground">Session</p>
                    <p class="mt-1 truncate font-mono">${escapeDebugHtml(event.sessionId)}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">User</p>
                    <p class="mt-1 truncate font-mono">${escapeDebugHtml(event.userId)}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Ref/Campaign</p>
                    <p class="mt-1 truncate font-mono">${escapeDebugHtml(event.ref ?? "Not captured")}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Affiliate</p>
                    <p class="mt-1 truncate font-mono">${escapeDebugHtml(event.affiliate ?? "Not captured")}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Occurred</p>
                    <p class="mt-1">${escapeDebugHtml(new Date(event.occurredAt).toLocaleString())}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Received</p>
                    <p class="mt-1">${escapeDebugHtml(new Date(event.receivedAt).toLocaleString())}</p>
                  </div>
                </div>
                <div>
                  <p class="text-xs text-muted-foreground">Properties</p>
                  <pre class="mt-2 max-h-72 overflow-auto rounded-md border bg-muted p-3 text-xs leading-5"><code>${escapeDebugHtml(properties)}</code></pre>
                </div>
              </div>
              <div class="flex justify-end border-t p-3">
                <button class="h-8 rounded-md border px-3 text-sm font-medium hover:bg-muted" type="button" data-close-event>Close</button>
              </div>
            </dialog>`;
        })
        .join("");
    };

    document.querySelectorAll<HTMLElement>("[data-live-debug-stream]").forEach((stream) => {
      const endpoint = stream.dataset.eventsEndpoint;
      const list = stream.querySelector<HTMLElement>("[data-debug-events-list]");
      const status = stream.querySelector<HTMLElement>("[data-debug-stream-status]");
      if (!endpoint || !list) return;

      let lastRenderedIds = Array.from(list.querySelectorAll<HTMLButtonElement>("[data-event-dialog]"))
        .map((button) => button.dataset.eventDialog)
        .join(",");

      const refreshDebugStream = async () => {
        try {
          const response = await fetch(endpoint, {
            cache: "no-store",
            headers: { accept: "application/json" },
          });
          if (!response.ok) throw new Error(`Debug stream fetch failed: ${response.status}`);

          const payload = (await response.json()) as { events?: LiveDebugEvent[] };
          const events = payload.events ?? [];
          const nextRenderedIds = events.map((event) => `event-${event.id}`).join(",");
          if (nextRenderedIds !== lastRenderedIds) {
            list.innerHTML = renderDebugEvents(events);
            lastRenderedIds = nextRenderedIds;
          }
          if (status) status.textContent = "Live";
        } catch {
          if (status) status.textContent = "Reconnecting";
        }
      };

      refreshDebugStream();
      setInterval(refreshDebugStream, 2000);
    });
  </script>
</AppLayout>
