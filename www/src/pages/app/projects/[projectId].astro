---
import { env } from "cloudflare:workers";
import { Activity, Bot, ChevronDown, Copy, ExternalLink, Globe2, KeyRound, Plus, Radio, RefreshCw, Search, TerminalSquare, UserRound, Webhook } from "lucide-react";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import InstallPanel from "@/components/InstallPanel";
import { SessionFlowExplorer } from "@/components/SessionFlowExplorer";
import { Separator } from "@/components/ui/separator";
import AppLayout from "@/layouts/AppLayout.astro";
import {
  canAdministerAccount,
  createEnvironmentCredential,
  createWebhookEndpoint,
  environmentLabels,
  formatCount,
  getProject,
  getViewerAccount,
  hostedEndpointHost,
  projectEnvironmentOptions,
} from "@/lib/sarge-demo";

export const prerender = false;

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");

const account = await getViewerAccount(userId, env.DATABASE_URL);
const project = getProject(account, Astro.params.projectId ?? "");
if (!project) return Astro.redirect("/app");

const requestedEnvironment = Astro.url.searchParams.get("environment");
const selectedEnvironment =
  project.environments.find((environment) => environment.environment === requestedEnvironment) ??
  project.environments.find((environment) => environment.environment === "production") ??
  project.environments[0] ??
  project;
const selectedEnvironmentLabel = environmentLabels[selectedEnvironment.environment];
const environmentOptions = projectEnvironmentOptions.map((environment) => ({
  label: environmentLabels[environment],
  href: environment === "production" ? `/app/projects/${project.slug}` : `/app/projects/${project.slug}?environment=${environment}`,
  selected: environment === selectedEnvironment.environment,
}));

const canCreateWebhooks = canAdministerAccount(account);
const canManageCredentials = canAdministerAccount(account);
let webhookError = "";
let createdWebhookSecret = "";
let createdWebhookName = "";
let credentialError = "";
let createdServerCredentialToken = "";
let createdServerCredentialEndpoint = "";
let createdPostbackCredentialToken = "";
let createdPostbackCredentialEndpoint = "";
let webhookValues = {
  name: "",
  url: "",
  eventNames: "",
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "create-webhook") {
    webhookValues = {
      name: String(formData.get("webhookName") ?? ""),
      url: String(formData.get("webhookUrl") ?? ""),
      eventNames: String(formData.get("webhookEventNames") ?? ""),
    };

    if (!canCreateWebhooks) {
      webhookError = "Only admins can create webhooks.";
    } else {
      const result = await createWebhookEndpoint(userId, env.DATABASE_URL, selectedEnvironment.id, webhookValues);

      if (result.success) {
        selectedEnvironment.webhookEndpoints = [result.webhook, ...selectedEnvironment.webhookEndpoints];
        createdWebhookSecret = result.signingSecret;
        createdWebhookName = result.webhook.name;
        webhookValues = { name: "", url: "", eventNames: "" };
      } else {
        webhookError = result.error;
      }
    }
  }

  if (intent === "rotate-server-credential" || intent === "rotate-postback-token") {
    if (!canManageCredentials) {
      credentialError = "Only admins can manage server-side credentials.";
    } else {
      const kind = intent === "rotate-server-credential" ? "server" : "postback";
      const result = await createEnvironmentCredential(userId, env.DATABASE_URL, selectedEnvironment.id, kind);

      if (result.success) {
        if (result.kind === "server") {
          createdServerCredentialToken = result.token;
          createdServerCredentialEndpoint = result.endpoint;
          selectedEnvironment.serverEventSecretConfigured = true;
        } else {
          createdPostbackCredentialToken = result.token;
          createdPostbackCredentialEndpoint = result.endpoint;
          selectedEnvironment.postbackTokenConfigured = true;
        }
      } else {
        credentialError = result.error;
      }
    }
  }
}

const snippet = `<script>
  window._sarge = { queue: [["track", "page.view"]] };
</script>
<script async src="${selectedEnvironment.pixelUrl}"></script>`;
const publicVerifyUrl = `/verify/${selectedEnvironment.id}`;
const publicVerifyAbsoluteUrl = `https://sargetrack.app${publicVerifyUrl}`;
const llmInstallPrompt = `Add Sarge tracking for ${project.name} ${selectedEnvironmentLabel}.

Read these docs first:
- https://sargetrack.app/llms.txt
- https://sargetrack.app/docs/install.md
- https://sargetrack.app/docs/events.md

Install this pixel snippet as early as possible in the page:

${snippet}

Then emit window.sarge("track", "event.name", properties) for page, product, cart, checkout, and purchase actions. Keep existing Meta, Google, or analytics pixels in place. After wiring, open ${publicVerifyAbsoluteUrl} and verify the expected events appear in the public Sarge event stream.`;
const endpointHealthUrl = selectedEnvironment.endpointHealthUrl;
const pixelUrl = selectedEnvironment.pixelUrl;
const serverEventEndpoint = `https://${hostedEndpointHost}/v2/server/events`;
const postbackEndpointTemplate = `https://${hostedEndpointHost}/v2/postback/${selectedEnvironment.id}/{postbackToken}`;
const createdServerCredentialCurl = createdServerCredentialToken
  ? `curl -X POST "${serverEventEndpoint}" \\
  -H "authorization: Bearer ${createdServerCredentialToken}" \\
  -H "content-type: application/json" \\
  -d '{
    "siteId": "${selectedEnvironment.id}",
    "name": "purchase.completed",
    "eventId": "order_123",
    "userId": "customer_123",
    "properties": {
      "order_id": "order_123",
      "value": 129.99,
      "currency": "USD"
    }
  }'`
  : "";

const recentEvents = selectedEnvironment.recentEvents.slice(0, 12);
const flowEvents = selectedEnvironment.recentEvents.slice(0, 80);
const eventHosts = selectedEnvironment.eventHosts;
const webhookEndpoints = selectedEnvironment.webhookEndpoints;
const projectTesterUserId = buildProjectTesterUserId(selectedEnvironment.id, userId);
const recentUserOptions = buildRecentUserOptions(selectedEnvironment.recentEvents, projectTesterUserId);
const impersonationConsoleSnippet = buildImpersonationConsoleSnippet(projectTesterUserId);
const isAiReviewEnabled = selectedEnvironment.environment === "production";
const diagnostics = isAiReviewEnabled ? selectedEnvironment.diagnostics : [];
const hasSelectedEnvironmentEvents =
  selectedEnvironment.eventCount24h > 0 || selectedEnvironment.recentEvents.length > 0;
const pixelInstallStatus = getPixelInstallStatus(selectedEnvironment.status, hasSelectedEnvironmentEvents);
const endpointHealth = pixelInstallStatus === "active" ? "healthy" : "pending";
const isPixelActive = pixelInstallStatus === "active";
const criticalFindings = diagnostics.filter((finding) => finding.severity === "critical").length;
const warningFindings = diagnostics.filter((finding) => finding.severity === "warning").length;
const diagnosticRunLabel = selectedEnvironment.diagnosticRunAt ? new Date(selectedEnvironment.diagnosticRunAt).toLocaleString() : "Pending first scheduled run";
const eventPulseBars = buildEventPulseBars(selectedEnvironment.recentEvents, selectedEnvironment.eventCount24h);
const eventTypeMix = buildEventTypeMix(selectedEnvironment.recentEvents);
const recentSessionCount = countUnique(selectedEnvironment.recentEvents.map((event) => event.sessionId));
const recentUserCount = countUnique(selectedEnvironment.recentEvents.map((event) => event.userId));
const severityVariant = (severity: string) => {
  if (severity === "critical") return "destructive";
  if (severity === "warning") return "secondary";
  return "outline";
};
const severityClass = (severity: string) => {
  if (severity === "critical") return "border-destructive/30 bg-destructive/5";
  if (severity === "warning") return "border-amber-500/30 bg-amber-500/5";
  return "border-border bg-card";
};
const isWatchdogEvent = (name: string) =>
  name === "meta.pixel.fire" || name === "google.tag.fire" || name === "data_layer.push";

function isTestTraffic(properties: Record<string, unknown>) {
  return properties.sarge_test === true;
}

const formatEventTime = (value: string) =>
  new Intl.DateTimeFormat("en-US", {
    hour: "numeric",
    minute: "2-digit",
    second: "2-digit",
  }).format(new Date(value));

const formatEventPayload = (value: Record<string, unknown>) => JSON.stringify(value, null, 2);

function buildEventPulseBars(events: typeof selectedEnvironment.recentEvents, eventCount24h: number) {
  const bucketCount = 10;
  const now = Date.now();
  const bucketMs = (24 * 60 * 60 * 1000) / bucketCount;
  const buckets = Array.from({ length: bucketCount }, (_, index) => ({
    label: `${24 - Math.round((index * 24) / bucketCount)}h`,
    value: 0,
  }));

  for (const event of events) {
    const ageMs = now - Date.parse(event.occurredAt);
    if (ageMs < 0 || ageMs > 24 * 60 * 60 * 1000) continue;

    const bucketIndex = Math.min(bucketCount - 1, Math.floor(ageMs / bucketMs));
    buckets[bucketCount - 1 - bucketIndex].value += 1;
  }

  if (!buckets.some((bucket) => bucket.value > 0) && eventCount24h > 0) {
    const weights = [0.38, 0.55, 0.44, 0.72, 0.66, 0.88, 0.7, 1, 0.82, 0.94];
    buckets.forEach((bucket, index) => {
      bucket.value = Math.max(1, Math.round((eventCount24h / 7) * weights[index]));
    });
  }

  const maxValue = Math.max(1, ...buckets.map((bucket) => bucket.value));
  return buckets.map((bucket) => ({
    ...bucket,
    height: Math.max(6, Math.round((bucket.value / maxValue) * 100)),
  }));
}

function buildEventTypeMix(events: typeof selectedEnvironment.recentEvents) {
  const eventCounts = new Map<string, number>();
  for (const event of events) {
    eventCounts.set(event.name, (eventCounts.get(event.name) ?? 0) + 1);
  }

  const total = Math.max(1, events.length);
  return Array.from(eventCounts.entries())
    .map(([name, value]) => ({
      name,
      value,
      share: Math.round((value / total) * 100),
    }))
    .sort((left, right) => right.value - left.value)
    .slice(0, 4);
}

function countUnique(values: string[]) {
  return new Set(values.filter(Boolean)).size;
}

function buildProjectTesterUserId(projectId: string, viewerUserId: string) {
  return `sarge_test_${hashId(`${projectId}:${viewerUserId}`)}`;
}

function buildRecentUserOptions(events: typeof selectedEnvironment.recentEvents, currentUserId: string) {
  const usersById = new Map<string, { userId: string; eventCount: number; lastEventAt: string }>();

  for (const event of events) {
    if (!event.userId || event.userId === currentUserId || isTestTraffic(event.properties)) continue;

    const existing = usersById.get(event.userId);
    if (!existing) {
      usersById.set(event.userId, {
        userId: event.userId,
        eventCount: 1,
        lastEventAt: event.occurredAt,
      });
      continue;
    }

    existing.eventCount += 1;
    if (Date.parse(event.occurredAt) > Date.parse(existing.lastEventAt)) {
      existing.lastEventAt = event.occurredAt;
    }
  }

  return Array.from(usersById.values())
    .sort((left, right) => Date.parse(right.lastEventAt) - Date.parse(left.lastEventAt))
    .slice(0, 8);
}

function buildImpersonationConsoleSnippet(userId: string) {
  return `impersonate('${escapeConsoleString(userId)}');`;
}

function escapeConsoleString(value: string) {
  return value.replace(/\\/g, "\\\\").replace(/'/g, "\\'");
}

function getPixelInstallStatus(configStatus: typeof selectedEnvironment.status, hasEvents: boolean) {
  if (configStatus !== "active") return configStatus;
  return hasEvents ? "active" : "pending";
}

function hashId(value: string) {
  let hash = 5381;
  for (let index = 0; index < value.length; index += 1) {
    hash = (hash * 33) ^ value.charCodeAt(index);
  }

  return (hash >>> 0).toString(36).padStart(6, "0");
}
---

<AppLayout
  account={account}
  title={`${project.name} | Sarge`}
  eyebrow="Project"
  heading={project.name}
  description="Copy install snippets, check project health, and watch for media/debug events."
  active="overview"
  breadcrumbs={[
    { label: "Overview", href: "/app" },
    { label: project.name },
  ]}
>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3 rounded-lg border bg-card p-2">
    <div class="inline-flex rounded-md bg-muted p-1">
      {
        environmentOptions.map((environmentOption) => (
          <a
            class:list={[
              "inline-flex h-7 items-center rounded-md px-3 text-sm font-medium transition-colors",
              environmentOption.selected
                ? "bg-background text-foreground shadow-sm"
                : "text-muted-foreground hover:bg-background/70 hover:text-foreground",
            ]}
            href={environmentOption.href}
            aria-current={environmentOption.selected ? "page" : undefined}
          >
            {environmentOption.label}
          </a>
        ))
      }
    </div>
    <p class="text-xs text-muted-foreground">Viewing {selectedEnvironmentLabel} for this project.</p>
  </div>

  <section class="mb-4 grid gap-4 lg:grid-cols-[minmax(0,1.1fr)_minmax(300px,0.9fr)]" data-project-pulse>
    <Card className="min-w-0">
      <CardHeader>
        <div class="flex min-w-0 flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Project pulse</p>
            <CardTitle className="mt-1 flex items-center gap-2">
              <Activity className="size-4 text-primary" /> Last 24 hours
            </CardTitle>
          </div>
          <div class="text-right">
            <p class="text-2xl font-semibold">{formatCount(selectedEnvironment.eventCount24h)}</p>
            <p class="text-xs text-muted-foreground">{selectedEnvironment.lastEventAt}</p>
          </div>
        </div>
      </CardHeader>
      <CardContent>
        <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_160px]">
          <div class="flex h-28 items-end gap-1 rounded-md border bg-muted/30 p-3" data-event-pulse-bars>
            {eventPulseBars.map((bucket, index) => (
              <div class="grid h-full flex-1 items-end gap-1">
                <div class="flex h-full items-end rounded-sm bg-secondary p-px">
                  <div
                    class:list={[
                      "w-full rounded-sm",
                      index === eventPulseBars.length - 1 ? "bg-primary" : "bg-primary/65",
                    ]}
                    style={`height: ${bucket.height}%`}
                    title={`${bucket.value} events around ${bucket.label}`}
                  />
                </div>
              </div>
            ))}
          </div>
          <div class="grid gap-3 text-sm">
            <div class="rounded-md border p-3">
              <p class="text-xs text-muted-foreground">Recent sessions</p>
              <p class="mt-1 text-2xl font-semibold">{formatCount(recentSessionCount)}</p>
            </div>
            <div class="rounded-md border p-3">
              <p class="text-xs text-muted-foreground">Recent users</p>
              <p class="mt-1 text-2xl font-semibold">{formatCount(recentUserCount)}</p>
            </div>
          </div>
        </div>
      </CardContent>
    </Card>

    <Card className="min-w-0">
      <CardHeader>
        <CardTitle>Event mix</CardTitle>
      </CardHeader>
      <CardContent className="grid gap-3">
        {
          eventTypeMix.length > 0 ? (
            eventTypeMix.map((eventType, index) => (
              <div class="grid gap-2">
                <div class="flex min-w-0 items-center justify-between gap-3">
                  <p class="truncate font-mono text-xs">{eventType.name}</p>
                  <Badge variant="outline">{eventType.value}</Badge>
                </div>
                <div class="h-2 rounded-full bg-secondary">
                  <div
                    class:list={[
                      "h-full rounded-full",
                      index === 0 ? "bg-primary" : index === 1 ? "bg-chart-2" : index === 2 ? "bg-chart-4" : "bg-chart-5",
                    ]}
                    style={`width: ${eventType.share}%`}
                  />
                </div>
              </div>
            ))
          ) : (
            <div class="rounded-md border border-dashed p-4 text-sm text-muted-foreground">
              Event mix appears after tracked actions arrive.
            </div>
          )
        }
      </CardContent>
    </Card>
  </section>

  <section class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_320px]">
      <details
        class="group/install flex flex-col gap-4 overflow-hidden rounded-xl bg-card py-4 text-sm text-card-foreground ring-1 ring-foreground/10 lg:col-span-2"
        data-install-pixel-details
        open={!isPixelActive}
      >
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 outline-none transition-colors hover:text-foreground focus-visible:ring-3 focus-visible:ring-ring/50 [&::-webkit-details-marker]:hidden">
          <span class="font-heading text-base leading-snug font-medium">Install pixel</span>
          <span class="inline-flex items-center gap-2">
            <Badge>{pixelInstallStatus}</Badge>
            <ChevronDown className="size-4 text-muted-foreground transition-transform group-open/install:rotate-180" />
          </span>
        </summary>
        <div class="px-4">
          <pre class="overflow-x-auto rounded-md border bg-muted p-4 text-xs leading-6"><code>{snippet}</code></pre>
          <div class="mt-4 flex flex-wrap gap-2">
            <Button data-copy-snippet data-snippet={snippet}>
              <Copy className="mr-2 size-4" />
              <span data-copy-label>Copy snippet</span>
            </Button>
            <a
              class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg border border-border bg-background px-2.5 text-sm font-medium whitespace-nowrap transition-all hover:bg-muted hover:text-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
              href={endpointHealthUrl}
              target="_blank"
              rel="noreferrer"
            >
              <ExternalLink className="size-4" /> Check status
            </a>
            <a
              class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg border border-border bg-background px-2.5 text-sm font-medium whitespace-nowrap transition-all hover:bg-muted hover:text-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
              href={pixelUrl}
              target="_blank"
              rel="noreferrer"
            >
              <ExternalLink className="size-4" /> Open pixel
            </a>
            <a
              class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg border border-border bg-background px-2.5 text-sm font-medium whitespace-nowrap transition-all hover:bg-muted hover:text-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
              href={publicVerifyUrl}
              target="_blank"
              rel="noreferrer"
            >
              <ExternalLink className="size-4" /> Public verify
            </a>
          </div>
          <div class="mt-4 rounded-md border bg-card p-4 text-sm">
            <p class="font-medium">Install checklist</p>
            <ol class="mt-2 list-decimal space-y-1 pl-4 text-muted-foreground">
              <li>Paste the snippet into the site head or as early as possible in the page body.</li>
              <li>Emit `window.sarge("track", "event.name", properties)` for key user actions.</li>
              <li>Reload the site and confirm events arrive in the debug stream below.</li>
            </ol>
            <a
              class="mt-3 inline-flex items-center text-sm font-medium text-primary hover:underline"
              href="/docs/events"
              target="_blank"
              rel="noreferrer"
            >
              View event names and payload examples <ExternalLink className="ml-1 size-3.5" />
            </a>
          </div>
          <div class="mt-4">
            <InstallPanel
              client:only="react"
              title="LLM setup"
              description="Copy a project-specific Sarge prompt for Claude Code, Codex, or Cursor."
              prompt={llmInstallPrompt}
            />
          </div>
        </div>
      </details>

      <Card className="min-w-0 lg:col-span-2" data-ai-review-card>
        <CardHeader>
          <div class="flex min-w-0 flex-wrap items-start justify-between gap-3">
            <div class="min-w-0">
              <CardTitle className="flex items-center gap-2">
                <Bot className="size-4" /> AI review
              </CardTitle>
              <p class="mt-1 text-sm text-muted-foreground">
                Deterministic checks over recent events, formatted for agentic code fixes.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <Badge variant={criticalFindings > 0 ? "destructive" : "outline"}>{criticalFindings} critical</Badge>
              <Badge variant={warningFindings > 0 ? "secondary" : "outline"}>{warningFindings} warnings</Badge>
            </div>
          </div>
        </CardHeader>
        <CardContent className="grid min-w-0 gap-3">
          {
            isAiReviewEnabled && selectedEnvironment.diagnosticSummary && (
              <div class="min-w-0 rounded-md border bg-muted p-4 text-sm">
                <p class="text-xs font-medium text-muted-foreground">AI summary</p>
                <p class="mt-1 leading-6">{selectedEnvironment.diagnosticSummary}</p>
              </div>
            )
          }
          {
            isAiReviewEnabled ? (
              <p class="text-xs text-muted-foreground">Last scheduled review: {diagnosticRunLabel}</p>
            ) : (
              <div class="rounded-md border border-dashed p-6 text-sm text-muted-foreground">
                AI recommendations are available for Production. {selectedEnvironmentLabel} still has its own pixel, session flows, debug stream, event hosts, and webhooks.
              </div>
            )
          }
          {
            isAiReviewEnabled && diagnostics.length > 0 ? (
              diagnostics.map((finding) => (
                <div class={`rounded-md border p-4 min-w-0 overflow-hidden ${severityClass(finding.severity)}`}>
                  <div class="flex min-w-0 flex-wrap items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-center gap-2">
                        <p class="font-medium">{finding.title}</p>
                        <Badge variant={severityVariant(finding.severity)}>{finding.severity}</Badge>
                      </div>
                      <p class="mt-1 text-sm text-muted-foreground">{finding.summary}</p>
                    </div>
                    <button
                      class="inline-flex h-7 shrink-0 items-center justify-center gap-1 rounded-md border bg-background px-2 text-xs font-medium hover:bg-muted"
                      type="button"
                      data-copy-prompt
                      data-prompt={finding.agentPrompt}
                    >
                      <Copy className="size-3" /> <span data-prompt-label>Copy prompt</span>
                    </button>
                  </div>
                  <div class="mt-3 grid min-w-0 gap-3 text-sm md:grid-cols-2">
                    <div class="min-w-0">
                      <p class="text-xs font-medium text-muted-foreground">Evidence</p>
                      <ul class="mt-1 list-disc space-y-1 pl-4 text-muted-foreground">
                        {finding.evidence.map((item) => <li>{item}</li>)}
                      </ul>
                    </div>
                    <div class="min-w-0">
                      <p class="text-xs font-medium text-muted-foreground">Recommendation</p>
                      <p class="mt-1 text-muted-foreground">{finding.recommendation}</p>
                    </div>
                  </div>
                  <pre class="mt-3 max-w-full overflow-x-auto rounded-md border bg-background p-3 text-xs leading-5"><code>{finding.agentPrompt}</code></pre>
                </div>
              ))
            ) : isAiReviewEnabled ? (
              <div class="rounded-md border border-dashed p-6 text-sm text-muted-foreground">
                No findings yet. Sarge needs recent events before it can review this project.
              </div>
            ) : null
          }
        </CardContent>
      </Card>

      <Card className="lg:col-span-2">
        <CardHeader>
          <CardTitle>User and session flows</CardTitle>
        </CardHeader>
        <CardContent>
          <SessionFlowExplorer events={flowEvents} client:only="react" />
        </CardContent>
      </Card>

      <div class="grid gap-4 lg:col-span-2 xl:grid-cols-2">
        <Card data-test-impersonation-card>
          <CardHeader>
            <CardTitle className="flex items-center gap-2"><UserRound className="size-4" /> Test impersonation</CardTitle>
          </CardHeader>
          <CardContent className="grid gap-4 text-sm">
            <div class="grid gap-2">
              <p class="text-xs text-muted-foreground">Your project test user ID</p>
              <div class="flex min-w-0 items-center gap-2 rounded-md border bg-muted p-2">
                <code class="min-w-0 flex-1 truncate font-mono text-xs" data-project-tester-id>{projectTesterUserId}</code>
                <button
                  class="inline-flex h-7 shrink-0 items-center justify-center gap-1 rounded-md border bg-background px-2 text-xs font-medium hover:bg-muted"
                  type="button"
                  data-copy-tester-id
                  data-tester-id={projectTesterUserId}
                >
                  <Copy className="size-3" /> <span data-copy-tester-id-label>Copy</span>
                </button>
              </div>
            </div>

            <div class="grid gap-2">
              <Label htmlFor="impersonationUserId">User to impersonate</Label>
              <Input
                id="impersonationUserId"
                value={projectTesterUserId}
                data-impersonation-user-input
                autocomplete="off"
                spellcheck="false"
              />
              <p class="text-xs text-muted-foreground">Paste this on the tracked site page console before running the flow. Use <code class="font-mono">clear_impersonation()</code> when finished.</p>
            </div>

            <div class="grid gap-2">
              <p class="text-xs text-muted-foreground">Recent users</p>
              {
                recentUserOptions.length > 0 ? (
                  <div class="flex max-h-36 flex-wrap gap-1.5 overflow-auto rounded-md border bg-background p-2">
                    {recentUserOptions.map((recentUser) => (
                      <button
                        class="inline-flex min-w-0 max-w-full items-center gap-1.5 rounded-md border bg-muted px-2 py-1 text-left font-mono text-xs hover:bg-background"
                        type="button"
                        data-recent-impersonation-user
                        data-user-id={recentUser.userId}
                        title={`${recentUser.userId} · ${recentUser.eventCount} events`}
                      >
                        <span class="truncate">{recentUser.userId}</span>
                        <Badge variant="outline">{recentUser.eventCount}</Badge>
                      </button>
                    ))}
                  </div>
                ) : (
                  <div class="rounded-md border border-dashed p-3 text-xs text-muted-foreground">
                    Recent users will appear after this project receives events.
                  </div>
                )
              }
            </div>

            <div class="grid gap-2">
              <div class="flex items-center justify-between gap-2">
                <p class="text-xs text-muted-foreground">Console line</p>
                <button
                  class="inline-flex h-7 shrink-0 items-center justify-center gap-1 rounded-md border bg-background px-2 text-xs font-medium hover:bg-muted"
                  type="button"
                  data-copy-impersonation-code
                >
                  <Copy className="size-3" /> <span data-copy-impersonation-code-label>Copy code</span>
                </button>
              </div>
              <pre class="max-w-full overflow-x-auto rounded-md border bg-muted p-3 text-xs leading-5"><code data-impersonation-code>{impersonationConsoleSnippet}</code></pre>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
          <CardTitle className="flex items-center gap-2"><KeyRound className="size-4" /> Server-side calls</CardTitle>
        </CardHeader>
        <CardContent className="grid gap-4 text-sm">
          {
            credentialError && (
              <Alert variant="destructive">
                  <AlertTitle>Credential was not rotated</AlertTitle>
                  <AlertDescription>{credentialError}</AlertDescription>
                </Alert>
              )
            }

            <div class="grid gap-3">
              <div class="rounded-md border p-3">
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0">
                    <p class="font-medium">Server event secret</p>
                    <p class="mt-1 break-all font-mono text-xs text-muted-foreground">{serverEventEndpoint}</p>
                  </div>
                  <Badge variant={selectedEnvironment.serverEventSecretConfigured ? "default" : "secondary"}>
                    {selectedEnvironment.serverEventSecretConfigured ? "configured" : "not set"}
                  </Badge>
                </div>
                {
                  createdServerCredentialToken && (
                    <Alert className="mt-3">
                      <AlertTitle>Server event secret rotated</AlertTitle>
                      <AlertDescription>
                        <p>Copy this value now. Sarge stores only the hash and will not show it again.</p>
                        <div class="mt-2 grid gap-2 rounded-md border bg-muted p-2">
                          <div class="flex min-w-0 items-start gap-2">
                            <pre class="min-w-0 flex-1 overflow-x-auto whitespace-pre-wrap rounded-md bg-background/60 p-2 font-mono text-xs leading-5"><code>{createdServerCredentialCurl}</code></pre>
                            <button
                              class="inline-flex h-7 shrink-0 items-center justify-center gap-1 rounded-md border bg-background px-2 text-xs font-medium hover:bg-muted"
                              type="button"
                              data-copy-credential
                              data-credential={createdServerCredentialCurl}
                            >
                              <Copy className="size-3" /> <span data-credential-label>Copy</span>
                            </button>
                          </div>
                          <p class="break-all font-mono text-xs text-muted-foreground">{createdServerCredentialEndpoint}</p>
                        </div>
                      </AlertDescription>
                    </Alert>
                  )
                }
                {
                  canManageCredentials ? (
                    <form method="post" class="mt-3">
                      <input type="hidden" name="intent" value="rotate-server-credential" />
                      <Button type="submit" variant="outline">
                        <RefreshCw className="mr-2 size-4" /> {selectedEnvironment.serverEventSecretConfigured ? "Rotate secret" : "Create secret"}
                      </Button>
                    </form>
                  ) : (
                    <p class="mt-3 text-xs text-muted-foreground">Ask an account admin to rotate this secret.</p>
                  )
                }
              </div>

              <div class="rounded-md border p-3">
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0">
                    <p class="font-medium">Postback token</p>
                    <p class="mt-1 break-all font-mono text-xs text-muted-foreground">{postbackEndpointTemplate}</p>
                  </div>
                  <Badge variant={selectedEnvironment.postbackTokenConfigured ? "default" : "secondary"}>
                    {selectedEnvironment.postbackTokenConfigured ? "configured" : "not set"}
                  </Badge>
                </div>
                {
                  createdPostbackCredentialToken && (
                    <Alert className="mt-3">
                      <AlertTitle>Postback token rotated</AlertTitle>
                      <AlertDescription>
                        <p>Copy this value now. Sarge stores only the hash and will not show it again.</p>
                        <div class="mt-2 grid gap-2 rounded-md border bg-muted p-2">
                          <div class="flex min-w-0 items-center gap-2">
                            <code class="min-w-0 flex-1 truncate font-mono text-xs">{createdPostbackCredentialToken}</code>
                            <button
                              class="inline-flex h-7 shrink-0 items-center justify-center gap-1 rounded-md border bg-background px-2 text-xs font-medium hover:bg-muted"
                              type="button"
                              data-copy-credential
                              data-credential={createdPostbackCredentialToken}
                            >
                              <Copy className="size-3" /> <span data-credential-label>Copy</span>
                            </button>
                          </div>
                          <p class="break-all font-mono text-xs text-muted-foreground">{createdPostbackCredentialEndpoint}</p>
                        </div>
                      </AlertDescription>
                    </Alert>
                  )
                }
                {
                  canManageCredentials ? (
                    <form method="post" class="mt-3">
                      <input type="hidden" name="intent" value="rotate-postback-token" />
                      <Button type="submit" variant="outline">
                        <RefreshCw className="mr-2 size-4" /> {selectedEnvironment.postbackTokenConfigured ? "Rotate token" : "Create token"}
                      </Button>
                    </form>
                  ) : (
                    <p class="mt-3 text-xs text-muted-foreground">Ask an account admin to rotate this token.</p>
                  )
                }
              </div>
            </div>
          </CardContent>
        </Card>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>Debug stream</CardTitle>
        </CardHeader>
        <CardContent className="grid gap-3">
          {
            recentEvents.length > 0 ? (
              recentEvents.map((event) => (
                <>
                  <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 rounded-md border p-3">
                    {
                      isWatchdogEvent(event.name) ? (
                        <TerminalSquare className="size-4 text-cyan-400" />
                      ) : (
                        <Radio className="size-4 text-primary" />
                      )
                    }
                    <div class="min-w-0">
                      <div class="flex min-w-0 flex-wrap items-center gap-2">
                        <p class="font-mono text-sm">{event.name}</p>
                        {isTestTraffic(event.properties) && <Badge variant="secondary">Test</Badge>}
                      </div>
                      <p class="truncate text-xs text-muted-foreground">
                        {event.title ?? event.url ?? "Untitled event"} · {formatEventTime(event.occurredAt)}
                      </p>
                    </div>
                    <button
                      class="inline-flex h-7 items-center justify-center gap-1 rounded-md border px-2 text-xs font-medium hover:bg-muted"
                      type="button"
                      data-open-event
                      data-event-dialog={`event-${event.id}`}
                    >
                      <Search className="size-3" /> Details
                    </button>
                  </div>
                  <dialog id={`event-${event.id}`} class="w-[min(720px,calc(100vw-2rem))] rounded-lg border bg-card p-0 text-card-foreground shadow-xl backdrop:bg-black/20">
                    <div class="border-b p-4">
                      <div class="flex min-w-0 flex-wrap items-center gap-2">
                        <p class="font-mono text-sm">{event.name}</p>
                        {isTestTraffic(event.properties) && <Badge variant="secondary">Test</Badge>}
                      </div>
                      <p class="mt-1 text-xs text-muted-foreground">{event.url ?? "No URL recorded"}</p>
                    </div>
                    <div class="grid gap-4 p-4 text-sm">
                      <div class="grid gap-3 sm:grid-cols-2">
                        <div>
                          <p class="text-xs text-muted-foreground">Session</p>
                          <p class="mt-1 truncate font-mono">{event.sessionId}</p>
                        </div>
                        <div>
                          <p class="text-xs text-muted-foreground">User</p>
                          <p class="mt-1 truncate font-mono">{event.userId}</p>
                        </div>
                        <div>
                          <p class="text-xs text-muted-foreground">Occurred</p>
                          <p class="mt-1">{new Date(event.occurredAt).toLocaleString()}</p>
                        </div>
                        <div>
                          <p class="text-xs text-muted-foreground">Received</p>
                          <p class="mt-1">{new Date(event.receivedAt).toLocaleString()}</p>
                        </div>
                      </div>
                      <div>
                        <p class="text-xs text-muted-foreground">Properties</p>
                        <pre class="mt-2 max-h-72 overflow-auto rounded-md border bg-muted p-3 text-xs leading-5"><code>{formatEventPayload(event.properties)}</code></pre>
                      </div>
                    </div>
                    <div class="flex justify-end border-t p-3">
                      <button class="h-8 rounded-md border px-3 text-sm font-medium hover:bg-muted" type="button" data-close-event>Close</button>
                    </div>
                  </dialog>
                </>
              ))
            ) : (
              <div class="rounded-md border border-dashed p-6 text-sm text-muted-foreground">
                No live events yet. Open the sample shop and click around to populate this stream.
              </div>
            )
          }
        </CardContent>
      </Card>
    <aside class="grid content-start gap-4">
      <Card>
        <CardHeader>
          <CardTitle>Install details</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3 text-sm">
          <div>
            <p class="text-xs text-muted-foreground">Tracking domain</p>
            <p class="font-mono">{selectedEnvironment.endpointHost}</p>
          </div>
          <Separator />
          <div>
            <p class="text-xs text-muted-foreground">Connection status</p>
            <p class="mt-1"><Badge variant={endpointHealth === "healthy" ? "default" : "secondary"}>{endpointHealth}</Badge></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground">Install URL</p>
            <p class="break-all font-mono text-xs">{selectedEnvironment.pixelUrl}</p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground">Environment</p>
            <p>{selectedEnvironmentLabel}</p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground">Snippet version</p>
            <p>{selectedEnvironment.pixelVersion}</p>
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle className="flex items-center gap-2"><Webhook className="size-4" /> Webhooks</CardTitle>
        </CardHeader>
        <CardContent className="grid gap-4 text-sm">
          {
            createdWebhookSecret && (
              <Alert>
                <AlertTitle>{createdWebhookName} created</AlertTitle>
                <AlertDescription>
                  <p>Copy this signing secret now. It will not be shown again.</p>
                  <div class="mt-2 flex min-w-0 items-center gap-2 rounded-md border bg-muted p-2">
                    <code class="min-w-0 flex-1 truncate font-mono text-xs">{createdWebhookSecret}</code>
                    <button
                      class="inline-flex h-7 shrink-0 items-center justify-center gap-1 rounded-md border bg-background px-2 text-xs font-medium hover:bg-muted"
                      type="button"
                      data-copy-webhook-secret
                      data-secret={createdWebhookSecret}
                    >
                      <Copy className="size-3" /> <span data-webhook-secret-label>Copy</span>
                    </button>
                  </div>
                </AlertDescription>
              </Alert>
            )
          }
          {
            webhookError && (
              <Alert variant="destructive">
                <AlertTitle>Webhook was not created</AlertTitle>
                <AlertDescription>{webhookError}</AlertDescription>
              </Alert>
            )
          }

          {
            canCreateWebhooks ? (
              <form method="post" class="grid gap-3">
                <input type="hidden" name="intent" value="create-webhook" />
                <div class="grid gap-2">
                  <Label htmlFor="webhookName">Name</Label>
                  <Input id="webhookName" name="webhookName" value={webhookValues.name} placeholder="n8n purchase trigger" required />
                </div>
                <div class="grid gap-2">
                  <Label htmlFor="webhookUrl">Destination URL</Label>
                  <Input id="webhookUrl" name="webhookUrl" type="url" value={webhookValues.url} placeholder="https://hooks.example.com/sarge" required />
                </div>
                <div class="grid gap-2">
                  <Label htmlFor="webhookEventNames">Event filters</Label>
                  <textarea
                    id="webhookEventNames"
                    name="webhookEventNames"
                    class="min-h-20 w-full min-w-0 rounded-lg border border-input bg-transparent px-2.5 py-2 text-sm outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
                    placeholder="purchase.completed, checkout.started"
                  >{webhookValues.eventNames}</textarea>
                  <p class="text-xs text-muted-foreground">Optional. Leave blank to receive all events.</p>
                </div>
                <Button type="submit"><Plus className="mr-2 size-4" /> Create webhook</Button>
              </form>
            ) : (
              <div class="rounded-md border border-dashed p-4 text-sm text-muted-foreground">
                Ask an account admin to create webhook destinations.
              </div>
            )
          }

          <Separator />

          <div class="grid gap-2">
            {
              webhookEndpoints.length > 0 ? (
                webhookEndpoints.map((webhookEndpoint) => (
                  <div class="grid gap-2 rounded-md border p-3">
                    <div class="flex min-w-0 items-start justify-between gap-2">
                      <div class="min-w-0">
                        <p class="truncate font-medium">{webhookEndpoint.name}</p>
                        <p class="mt-1 truncate font-mono text-xs text-muted-foreground">{webhookEndpoint.url}</p>
                      </div>
                      <Badge variant={webhookEndpoint.isActive ? "default" : "secondary"}>
                        {webhookEndpoint.isActive ? "active" : "paused"}
                      </Badge>
                    </div>
                    <div class="flex flex-wrap gap-1">
                      {
                        webhookEndpoint.eventNames.length > 0 ? (
                          webhookEndpoint.eventNames.map((eventName) => <Badge variant="outline">{eventName}</Badge>)
                        ) : (
                          <Badge variant="outline">All events</Badge>
                        )
                      }
                    </div>
                    <p class="text-xs text-muted-foreground">Created {new Date(webhookEndpoint.createdAt).toLocaleDateString()}</p>
                  </div>
                ))
              ) : (
                <div class="rounded-md border border-dashed p-4 text-sm text-muted-foreground">
                  No webhook destinations yet.
                </div>
              )
            }
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle className="flex items-center gap-2"><Globe2 className="size-4" /> Event hosts</CardTitle>
        </CardHeader>
        <CardContent className="grid gap-3 text-sm">
          {
            eventHosts.length > 0 ? (
              eventHosts.map((eventHost) => (
                <div class="grid grid-cols-[1fr_auto] items-center gap-3 rounded-md border p-3">
                  <div class="min-w-0">
                    <p class="truncate font-mono text-xs">{eventHost.host}</p>
                    <p class="mt-1 text-xs text-muted-foreground">{formatEventTime(eventHost.lastEventAt)}</p>
                  </div>
                  <Badge variant="outline">{eventHost.count}</Badge>
                </div>
              ))
            ) : (
              <div class="rounded-md border border-dashed p-4 text-sm text-muted-foreground">
                No event hosts recorded in the 10 most recent events.
              </div>
            )
          }
        </CardContent>
      </Card>
    </aside>
  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>("[data-copy-snippet]").forEach((button) => {
      button.addEventListener("click", async () => {
        const snippet = button.dataset.snippet;
        if (!snippet) return;

        try {
          await navigator.clipboard.writeText(snippet);
          const label = button.querySelector("[data-copy-label]");
          const originalText = label?.textContent ?? "Copy snippet";
          if (label) label.textContent = "Copied";
          window.setTimeout(() => {
            if (label) label.textContent = originalText;
          }, 1600);
        } catch {
          const label = button.querySelector("[data-copy-label]");
          if (label) label.textContent = "Copy failed";
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-open-event]").forEach((button) => {
      button.addEventListener("click", () => {
        const dialog = document.getElementById(button.dataset.eventDialog ?? "");
        if (dialog instanceof HTMLDialogElement) dialog.showModal();
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-close-event]").forEach((button) => {
      button.addEventListener("click", () => {
        button.closest("dialog")?.close();
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-copy-prompt]").forEach((button) => {
      button.addEventListener("click", async () => {
        const prompt = button.dataset.prompt;
        if (!prompt) return;

        const label = button.querySelector("[data-prompt-label]");
        try {
          await navigator.clipboard.writeText(prompt);
          const originalText = label?.textContent ?? "Copy prompt";
          if (label) label.textContent = "Copied";
          window.setTimeout(() => {
            if (label) label.textContent = originalText;
          }, 1600);
        } catch {
          if (label) label.textContent = "Copy failed";
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-copy-webhook-secret]").forEach((button) => {
      button.addEventListener("click", async () => {
        const secret = button.dataset.secret;
        if (!secret) return;

        const label = button.querySelector("[data-webhook-secret-label]");
        try {
          await navigator.clipboard.writeText(secret);
          const originalText = label?.textContent ?? "Copy";
          if (label) label.textContent = "Copied";
          window.setTimeout(() => {
            if (label) label.textContent = originalText;
          }, 1600);
        } catch {
          if (label) label.textContent = "Copy failed";
        }
      });
    });

    const escapeImpersonationUserId = (value: string) => value.replace(/\\/g, "\\\\").replace(/'/g, "\\'");
    const buildImpersonationCode = (userId: string) => `impersonate('${escapeImpersonationUserId(userId)}');`;

    const copyTextWithLabel = async (text: string, label: Element | null, fallback: string) => {
      try {
        await navigator.clipboard.writeText(text);
        const originalText = label?.textContent ?? fallback;
        if (label) label.textContent = "Copied";
        window.setTimeout(() => {
          if (label) label.textContent = originalText;
        }, 1600);
      } catch {
        if (label) label.textContent = "Copy failed";
      }
    };

    document.querySelectorAll<HTMLButtonElement>("[data-copy-credential]").forEach((button) => {
      button.addEventListener("click", async () => {
        const credential = button.dataset.credential;
        if (!credential) return;

        await copyTextWithLabel(credential, button.querySelector("[data-credential-label]"), "Copy");
      });
    });

    document.querySelectorAll<HTMLElement>("[data-test-impersonation-card]").forEach((panel) => {
      const input = panel.querySelector<HTMLInputElement>("[data-impersonation-user-input]");
      const code = panel.querySelector<HTMLElement>("[data-impersonation-code]");
      if (!input || !code) return;

      const updateImpersonationCode = () => {
        code.textContent = buildImpersonationCode(input.value.trim());
      };

      input.addEventListener("input", updateImpersonationCode);

      panel.querySelectorAll<HTMLButtonElement>("[data-recent-impersonation-user]").forEach((button) => {
        button.addEventListener("click", () => {
          input.value = button.dataset.userId ?? "";
          updateImpersonationCode();
          input.focus();
        });
      });

      panel.querySelector<HTMLButtonElement>("[data-copy-tester-id]")?.addEventListener("click", async (event) => {
        const button = event.currentTarget;
        const testerId = button.dataset.testerId;
        if (!testerId) return;
        await copyTextWithLabel(testerId, button.querySelector("[data-copy-tester-id-label]"), "Copy");
      });

      panel.querySelector<HTMLButtonElement>("[data-copy-impersonation-code]")?.addEventListener("click", async (event) => {
        updateImpersonationCode();
        const button = event.currentTarget;
        await copyTextWithLabel(code.textContent ?? "", button.querySelector("[data-copy-impersonation-code-label]"), "Copy code");
      });
    });
  </script>
</AppLayout>
