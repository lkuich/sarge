---
import { Plus } from "lucide-react";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import AppLayout from "@/layouts/AppLayout.astro";
import { canAdministerAccount, formatCount, getViewerAccount } from "@/lib/sarge-demo";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");

const account = getViewerAccount(userId);
---

<AppLayout
  account={account}
  title="Projects | Sarge"
  heading="Projects"
  description="Each project gets its own install details, endpoint host, event stream, and debugging surface."
  active="projects"
>
  <div class="mb-4 flex items-center justify-between gap-3">
    <p class="text-sm text-muted-foreground">{account.projects.length} projects under {account.name}</p>
    {canAdministerAccount(account) && <Button><Plus className="mr-2 size-4" /> New project</Button>}
  </div>

  <section class="grid gap-4 md:grid-cols-2">
    {
      account.projects.map((project) => (
        <Card>
          <CardHeader>
            <div class="flex items-start justify-between gap-3">
              <div>
                <CardTitle><a href={`/app/projects/${project.slug}`}>{project.name}</a></CardTitle>
                <p class="mt-1 font-mono text-xs text-muted-foreground">{project.endpointHost}</p>
              </div>
              <Badge variant={project.status === "active" ? "default" : "secondary"}>{project.status}</Badge>
            </div>
          </CardHeader>
          <CardContent>
            <div class="grid grid-cols-3 gap-3 text-sm">
              <div>
                <p class="text-xs text-muted-foreground">Environment</p>
                <p class="font-medium">{project.environment}</p>
              </div>
              <div>
                <p class="text-xs text-muted-foreground">24h Events</p>
                <p class="font-medium">{formatCount(project.eventCount24h)}</p>
              </div>
              <div>
                <p class="text-xs text-muted-foreground">Pixel</p>
                <p class="font-medium">{project.pixelVersion}</p>
              </div>
            </div>
          </CardContent>
        </Card>
      ))
    }
  </section>
</AppLayout>
