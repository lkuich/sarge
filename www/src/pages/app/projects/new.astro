---
import { env } from "cloudflare:workers";
import { ArrowLeft, Plus } from "lucide-react";
import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import AppLayout from "@/layouts/AppLayout.astro";
import { canAdministerAccount, canCreateProjectForPlan, createProject, getViewerAccount } from "@/lib/sarge-demo";

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");
const currentUser = await Astro.locals.currentUser();
const viewerEmails = currentUser?.emailAddresses.map((email) => email.emailAddress).filter(Boolean) ?? [];

const account = await getViewerAccount(userId, env.DATABASE_URL, { viewerEmails });
if (!account.workspaceSetupComplete) return Astro.redirect("/app");
if (!canAdministerAccount(account)) return Astro.redirect("/app");
const canCreateMoreProjects = canCreateProjectForPlan(account);

let error = "";
let values = {
  name: "",
  domain: "",
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  values = {
    name: String(formData.get("name") ?? ""),
    domain: String(formData.get("domain") ?? ""),
  };
  if (!canCreateMoreProjects) {
    error = "Upgrade to add more projects.";
  } else {
    const result = await createProject(userId, env.DATABASE_URL, values);

    if (result.success) {
      return Astro.redirect(`/app/projects/${result.project.siteId}`, 303);
    }

    error = result.error;
  }
}
---

<AppLayout
  account={account}
  title="New project | Sarge"
  eyebrow="Project"
  heading="New project"
  description="Create a project, get its install snippet, and start collecting events."
  active="overview"
  breadcrumbs={[
    { label: "Overview", href: "/app" },
    { label: "New project" },
  ]}
>
  <section class="grid gap-4 lg:grid-cols-[1fr_340px]">
    <Card>
      <CardHeader>
        <CardTitle>Project details</CardTitle>
      </CardHeader>
      <CardContent>
        {error && (
          <Alert className="mb-4">
            <AlertTitle>Project was not created</AlertTitle>
            <AlertDescription>{error}</AlertDescription>
          </Alert>
        )}
        {!canCreateMoreProjects && (
          <Alert className="mb-4">
            <AlertTitle>Project limit reached</AlertTitle>
            <AlertDescription>Upgrade to add more projects.</AlertDescription>
          </Alert>
        )}

        <form method="post" class="grid gap-4">
          <div class="grid gap-2">
            <Label htmlFor="name">Name</Label>
            <Input id="name" name="name" value={values.name} placeholder="Checkout QA Site" required />
          </div>

          <div class="grid gap-2">
            <Label htmlFor="domain">Site domain</Label>
            <Input id="domain" name="domain" value={values.domain} placeholder="example.com" required />
            <p class="text-xs text-muted-foreground">Enter the domain of the site you are tracking. Sarge will use sarge.yourdomain.com for DNS and install assets.</p>
          </div>

          <div class="flex flex-wrap gap-2">
            <Button type="submit" disabled={!canCreateMoreProjects}><Plus className="mr-2 size-4" /> Create project</Button>
            <a
              class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg border border-border bg-background px-2.5 text-sm font-medium whitespace-nowrap transition-all hover:bg-muted hover:text-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
              href="/app"
            >
              <ArrowLeft className="size-4" /> Back to overview
            </a>
          </div>
        </form>
      </CardContent>
    </Card>

    <aside class="grid content-start gap-4">
      <Card>
        <CardHeader>
          <CardTitle>What happens next</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3 text-sm text-muted-foreground">
          <p>Your project is ready immediately. Add the install snippet to your site, then watch events arrive in Sarge.</p>
          <div class="grid gap-2 rounded-md border bg-card p-3">
            <p class="font-medium text-foreground">Included</p>
            <p>Hosted pixel, live event stream, scheduled reviews, and webhook destinations.</p>
          </div>
          <p>Sarge will generate DNS guidance and custom-domain install assets from your site domain.</p>
        </CardContent>
      </Card>
    </aside>
  </section>
</AppLayout>
