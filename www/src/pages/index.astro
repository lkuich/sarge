---
import { Show, SignInButton, SignUpButton } from "@clerk/astro/components";
import {
  ArrowRight,
  Bot,
  Bell,
  CircleX,
  Cloud,
  Code2,
  Database,
  Archive,
  Radio,
  Scale,
  ShieldCheck,
  Sparkles,
  TerminalSquare,
  Webhook,
  Zap,
} from "lucide-react";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import InstallPanel from "@/components/InstallPanel";
import SiteLayout from "@/layouts/SiteLayout.astro";

const events = [
  { name: "checkout.started", state: "accepted", tone: "border-emerald-400/40 text-emerald-200", icon: Radio },
  { name: "meta.pixel.fire", state: "observed", tone: "border-cyan-400/40 text-cyan-200", icon: TerminalSquare },
  { name: "purchase.completed", state: "missing", tone: "border-red-500/50 text-red-400", icon: CircleX, failed: true },
  { name: "agent.fix_ready", state: "ready", tone: "border-lime-300/40 text-lime-100", icon: Bot, succeeded: true },
];

const loop = [
  {
    title: "Install the (tiny) pixel",
    description: "Drop in one hosted script or let an agent use the Sarge install skill to wire events across your app.",
    icon: Code2,
  },
  {
    title: "Watch everything fire",
    description: "Sarge records your first-party events and observes Meta, Google, and dataLayer calls on the page.",
    icon: Radio,
  },
  {
    title: "Run scheduled reviews",
    description: "On a schedule, Sarge runs diagnostics across your events and uses AI to summarize only the real issues — so you skip the noise.",
    icon: Cloud,
  },
  {
    title: "Hand off the fix",
    description: "Context enriched from the pixel, the watchdog, and historical evidence is fed directly to your coding agent to get it fixed.",
    icon: Bot,
  },
];

const useCases = [
  {
    title: "Fire automations from real events",
    description: "Turn clean tracking events into webhooks for n8n, Make, Zapier, Slack, CRM updates, lead routing, and internal ops.",
    icon: Webhook,
  },
  {
    title: "Send sales data to your warehouse",
    description: "Pipe checkout, purchase, attribution, and campaign events into your own Postgres, BigQuery, Snowflake, or ClickHouse stack.",
    icon: Database,
  },
  {
    title: "Ask AI about marketing performance",
    description: "Stream structured event history into your LLM layer and ask questions like why Meta reported 40 purchases when Sarge saw 31.",
    icon: Sparkles,
  },
  {
    title: "Verify affiliate numbers",
    description: "Qualify affiliates with independent click, session, checkout, purchase, refund, and attribution-window evidence.",
    icon: Scale,
  },
  {
    title: "Audit ad platform reporting",
    description: "Compare Meta, Google, TikTok, affiliate, and first-party events against your own neutral source of truth.",
    icon: ShieldCheck,
  },
  {
    title: "Keep an audit trail",
    description: "Own the event history when dashboards change, attribution models shift, privacy rules bite, or a vendor report gets challenged.",
    icon: Archive,
  },
  {
    title: "Alert on silent failures",
    description: "Catch no-purchase windows, duplicate order IDs, broken purchase pixels, affiliate spikes, or missing required event fields.",
    icon: Bell,
  },
  {
    title: "Debug consent and blockers",
    description: "See what still fires when third-party scripts are blocked, delayed by consent, or loaded in the wrong order.",
    icon: Radio,
  },
];

---

<SiteLayout title="Sarge | Agent-ready tracking diagnostics" shader>
  <section class="relative mx-auto flex min-h-[calc(100svh-5rem)] w-full max-w-6xl flex-col justify-center px-4 pb-8 pt-12 md:px-6 md:pt-20">
    <div class="max-w-4xl">
      <h1 class="max-w-5xl text-5xl font-semibold leading-[0.95] md:text-7xl lg:text-8xl">
        Do you trust your tracking?
        <!-- Catch tracking bugs before your ad platforms lie to you. -->
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-white md:text-lg">
        A tiny event pixel, a watchdog for messy media scripts, and deep agent integration to proactively find and fix tracking issues before they cost you ad spend.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <Show when="signed-out">
          <SignUpButton mode="modal">
            <Button size="lg">
              Create account <ArrowRight className="ml-1 size-4" />
            </Button>
          </SignUpButton>
          <SignInButton mode="modal">
            <Button size="lg" variant="outline">Sign in</Button>
          </SignInButton>
        </Show>
        <Show when="signed-in">
          <a href="/app">
            <Button size="lg">
              Open dashboard <ArrowRight className="ml-1 size-4" />
            </Button>
          </a>
        </Show>
      </div>
    </div>

    <div class="mt-10 grid overflow-hidden rounded-lg border border-white/10 bg-background/70 backdrop-blur md:grid-cols-4">
      {
        events.map(({ name, state, tone, icon: Icon, failed, succeeded }) => (
          <div class={`grid grid-cols-[auto_1fr] gap-3 border-b border-white/10 p-4 last:border-b-0 md:border-b-0 md:border-r md:last:border-r-0 ${failed ? "bg-destructive/10" : succeeded ? "bg-success/10" : ""}`}>
            <Icon className={`mt-0.5 size-4 ${tone}`} />
            <div class="min-w-0">
              <p class="truncate font-mono text-sm">{name}</p>
              <p class={`mt-1 text-xs ${failed ? "font-semibold text-red-400" : succeeded ? "font-semibold text-green-400" : "text-muted-foreground"}`}>{state}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="border-y bg-background/88 px-4 py-12 backdrop-blur md:px-6">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[320px_1fr]">
      <div>
        <Badge variant="outline">Closed loop</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-4xl">From fired event to fix prompt.</h2>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          The product is not another passive analytics dashboard. It records what happened, checks what looks wrong, and prepares the exact implementation brief a coding agent needs.
        </p>
      </div>

      <div class="grid gap-3 md:grid-cols-2">
        {
          loop.map(({ title, description, icon: Icon }, index) => (
            <article class="rounded-lg border bg-card/80 p-5">
              <div class="flex items-center gap-3">
                <span class="grid size-8 place-items-center rounded-md border bg-muted font-mono text-xs">{index + 1}</span>
                <Icon className="size-6 text-primary" />
              </div>
              <h3 class="mt-5 text-lg font-semibold">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="setup" class="scroll-mt-20 bg-background px-4 py-14 md:px-6">
    <div class="mx-auto max-w-3xl">
      <Badge variant="secondary">Setup</Badge>
      <h2 class="mt-4 text-3xl font-semibold md:text-4xl">Two commands and you're tracking.</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">
        Install the skill so your agent knows which events to wire, then add the MCP so it can read your live stream and findings. Pick your tool:
      </p>
      <div class="mt-6 min-h-54">
        <InstallPanel client:only="react" />
      </div>
    </div>
  </section>

  <section id="use-cases" class="scroll-mt-20 border-y bg-muted/35 px-4 py-14 md:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <Badge variant="outline">Use cases</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Your own audit trail unlocks more than debugging.</h2>
        <p class="mt-4 text-sm leading-6 text-white">
          Once marketing events are stored in your own neutral ledger, they can trigger automations, feed your warehouse, verify partners, and give AI something factual to answer from.
        </p>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        {
          useCases.map(({ title, description, icon: Icon }) => (
            <article class="rounded-lg border bg-card p-5">
              <Icon className="size-5 text-primary" />
              <h3 class="mt-5 text-base font-semibold">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="pricing" class="scroll-mt-20 bg-background px-4 py-14 md:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <Badge variant="secondary">Deploy how you want</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Simple pricing.</h2>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-3">
        <article class="flex flex-col rounded-lg border bg-card p-5">
          <Zap className="size-5 text-primary" />
          <h3 class="mt-5 font-semibold">Free</h3>
          <p class="mt-1 text-2xl font-semibold">$0</p>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            The pixel, the watchdog, and on-demand diagnostics for a single site.
          </p>
          <div class="mt-auto pt-5">
            <SignUpButton mode="modal">
              <Button variant="outline" className="w-full">Sign up free</Button>
            </SignUpButton>
          </div>
        </article>
        <article class="flex flex-col rounded-lg border bg-card p-5">
          <Cloud className="size-5 text-primary" />
          <h3 class="mt-5 font-semibold">Hosted</h3>
          <p class="mt-1 text-2xl font-semibold"><span class="text-sm font-normal text-muted-foreground">from </span>$20<span class="text-sm font-normal text-muted-foreground"> /mo</span></p>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            We host everything: your pixel, endpoint, and scheduled diagnostics. Drop in the snippet and go.
          </p>
          <div class="mt-auto pt-5">
            <SignUpButton mode="modal">
              <Button className="w-full">Sign up</Button>
            </SignUpButton>
          </div>
        </article>
        <article class="flex flex-col rounded-lg border bg-card p-5">
          <TerminalSquare className="size-5 text-primary" />
          <h3 class="mt-5 font-semibold">Self-hosted</h3>
          <p class="mt-1 text-2xl font-semibold">BYO</p>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            Host the scripts, run the API and database yourself when you need the debug loop inside your own infrastructure.
          </p>
          <div class="mt-auto pt-5">
            <a href="/docs/self-hosting">
              <Button variant="outline" className="w-full">Read how <ArrowRight className="ml-1 size-3.5" /></Button>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <footer class="border-t bg-background/80 px-4 py-12 backdrop-blur md:px-6">
    <div class="mx-auto grid max-w-6xl gap-8 sm:grid-cols-2 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <img class="h-7 w-auto dark:hidden" src="/sarge-logo-light.svg" alt="Sarge" width="196" height="48" />
        <img class="hidden h-7 w-auto dark:block" src="/sarge-logo-dark.svg" alt="Sarge" width="196" height="48" />
        <p class="mt-3 max-w-xs text-sm leading-6 text-muted-foreground">
          Catch tracking bugs before your ad platforms lie to you.
        </p>
      </div>

      <nav aria-label="Product">
        <p class="text-sm font-semibold">Product</p>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li><a class="transition hover:text-foreground" href="#setup">Setup</a></li>
          <li><a class="transition hover:text-foreground" href="#use-cases">Use cases</a></li>
          <li><a class="transition hover:text-foreground" href="#pricing">Pricing</a></li>
        </ul>
      </nav>

      <nav aria-label="Account">
        <p class="text-sm font-semibold">Account</p>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <Show when="signed-out">
            <li>
              <SignInButton mode="modal">
                <button class="transition hover:text-foreground">Sign in</button>
              </SignInButton>
            </li>
            <li>
              <SignUpButton mode="modal">
                <button class="transition hover:text-foreground">Create account</button>
              </SignUpButton>
            </li>
          </Show>
          <Show when="signed-in">
            <li><a class="transition hover:text-foreground" href="/app">Dashboard</a></li>
          </Show>
        </ul>
      </nav>
    </div>

    <div class="mx-auto mt-10 flex max-w-6xl flex-col items-center justify-between gap-2 border-t pt-6 text-xs text-muted-foreground sm:flex-row">
      <p>© 2026 Sarge. All rights reserved.</p>
      <p>The idiot's pixel, with an AI review loop.</p>
    </div>
  </footer>
</SiteLayout>
