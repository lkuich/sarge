---
import { Show, SignInButton, SignUpButton } from "@clerk/astro/components";
import {
  ArrowRight,
  Bot,
  Cloud,
  Code2,
  Database,
  FileWarning,
  Radio,
  ShieldCheck,
  Sparkles,
  TerminalSquare,
  Zap,
} from "lucide-react";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import SiteLayout from "@/layouts/SiteLayout.astro";

const events = [
  { name: "checkout.started", state: "accepted", tone: "border-emerald-400/40 text-emerald-200", icon: Radio },
  { name: "meta.pixel.fire", state: "observed", tone: "border-cyan-400/40 text-cyan-200", icon: TerminalSquare },
  { name: "purchase.completed", state: "missing", tone: "border-amber-300/50 text-amber-100", icon: FileWarning },
  { name: "agent.fix_prompt", state: "ready", tone: "border-lime-300/40 text-lime-100", icon: Bot },
];

const loop = [
  {
    title: "Install the tiny pixel",
    description: "Drop in one hosted script or let an agent use the Sarge install skill to wire events across your app.",
    icon: Code2,
  },
  {
    title: "Watch everything fire",
    description: "Sarge records your first-party events and observes Meta, Google, and dataLayer calls on the page.",
    icon: Radio,
  },
  {
    title: "Run scheduled reviews",
    description: "On a schedule, Sarge runs diagnostics across your events and uses AI to summarize only the real issues — so you skip the noise.",
    icon: Cloud,
  },
  {
    title: "Hand off the fix",
    description: "Every finding includes evidence, a recommendation, and a copyable prompt for agentic coding tools.",
    icon: Bot,
  },
];

const features = [
  {
    title: "The idiot's pixel",
    description: "A deliberately simple event API: stable names, JSON properties, and no analytics ceremony.",
    icon: Zap,
  },
  {
    title: "Third-party watchdog",
    description: "Wraps `fbq`, `gtag`, and `dataLayer.push` so you can compare what Meta and Google recorded against your own source of truth.",
    icon: ShieldCheck,
  },
  {
    title: "Automatic AI reviews",
    description: "Scheduled diagnostics, summarized only when there's something to report — so reviews stay cheap and quiet.",
    icon: Sparkles,
  },
  {
    title: "Evidence that persists",
    description: "Every run and finding is stored, so you can see what changed over time instead of re-checking from scratch.",
    icon: Database,
  },
];

const installSnippet = `<script>
  window._sarge = { queue: [["track", "page.view"]] };
</script>
<script async src="https://sarge.lkuich.com/pixel.js?site=site_123"></script>`;
---

<SiteLayout title="Sarge | Agent-ready tracking diagnostics" shader>
  <section class="relative mx-auto flex min-h-[calc(100svh-5rem)] w-full max-w-6xl flex-col justify-center px-4 pb-8 pt-12 md:px-6 md:pt-20">
    <div class="max-w-4xl">
      <p class="mb-4 inline-flex rounded-full border border-white/15 bg-background/55 px-3 py-1 text-xs font-semibold uppercase text-muted-foreground backdrop-blur">
        The idiot's pixel, with an AI review loop
      </p>
      <h1 class="max-w-5xl text-5xl font-semibold leading-[0.95] md:text-7xl lg:text-8xl">
        Sarge catches tracking bugs before your ad platforms lie to you.
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-muted-foreground md:text-lg">
        A tiny event pixel, a watchdog for messy media scripts, and automatic diagnostics that turn broken tracking into agent-ready fix prompts.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <Show when="signed-out">
          <SignUpButton mode="modal">
            <Button size="lg">
              Create account <ArrowRight className="ml-1 size-4" />
            </Button>
          </SignUpButton>
          <SignInButton mode="modal">
            <Button size="lg" variant="outline">Sign in</Button>
          </SignInButton>
        </Show>
        <Show when="signed-in">
          <a href="/app">
            <Button size="lg">
              Open dashboard <ArrowRight className="ml-1 size-4" />
            </Button>
          </a>
        </Show>
      </div>
    </div>

    <div class="mt-10 grid overflow-hidden rounded-lg border border-white/10 bg-background/70 backdrop-blur md:grid-cols-4">
      {
        events.map(({ name, state, tone, icon: Icon }) => (
          <div class="grid grid-cols-[auto_1fr] gap-3 border-b border-white/10 p-4 last:border-b-0 md:border-b-0 md:border-r md:last:border-r-0">
            <Icon className={`mt-0.5 size-4 ${tone}`} />
            <div class="min-w-0">
              <p class="truncate font-mono text-sm">{name}</p>
              <p class="mt-1 text-xs text-muted-foreground">{state}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="border-y bg-background/88 px-4 py-12 backdrop-blur md:px-6">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[320px_1fr]">
      <div>
        <Badge variant="outline">Closed loop</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-4xl">From fired event to fix prompt.</h2>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          The product is not another passive analytics dashboard. It records what happened, checks what looks wrong, and prepares the exact implementation brief a coding agent needs.
        </p>
      </div>

      <div class="grid gap-3 md:grid-cols-2">
        {
          loop.map(({ title, description, icon: Icon }, index) => (
            <article class="rounded-lg border bg-card/80 p-5">
              <div class="flex items-center gap-3">
                <span class="grid size-8 place-items-center rounded-md border bg-muted font-mono text-xs">{index + 1}</span>
                <Icon className="size-4 text-primary" />
              </div>
              <h3 class="mt-5 text-lg font-semibold">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background px-4 py-14 md:px-6">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1fr_420px]">
      <div class="min-w-0">
        <Badge variant="secondary">Agent-native install</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Let your coding agent install it for you.</h2>
        <p class="mt-4 max-w-2xl text-sm leading-6 text-muted-foreground">
          Sarge ships with a repo-local skill that tells an agent how to install the SDK, where to place the script, which ecommerce events to wire, and how to verify the data stream.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-lg border bg-card p-4">
            <p class="font-mono text-xs text-muted-foreground">skill</p>
            <p class="mt-2 font-mono text-sm">.agents/skills/sarge-install</p>
          </div>
          <div class="rounded-lg border bg-card p-4">
            <p class="font-mono text-xs text-muted-foreground">prompt output</p>
            <p class="mt-2 text-sm">Evidence-backed implementation brief</p>
          </div>
        </div>
      </div>

      <div class="min-w-0 rounded-lg border bg-card">
        <div class="flex items-center justify-between border-b px-4 py-3">
          <p class="font-mono text-xs text-muted-foreground">hosted install</p>
          <Badge variant="outline">copy once</Badge>
        </div>
        <pre class="overflow-x-auto p-4 text-xs leading-6"><code>{installSnippet}</code></pre>
      </div>
    </div>
  </section>

  <section class="border-y bg-muted/35 px-4 py-14 md:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <Badge variant="outline">What makes it different</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Debugging features, not vanity metrics.</h2>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        {
          features.map(({ title, description, icon: Icon }) => (
            <article class="rounded-lg border bg-card p-5">
              <Icon className="size-5 text-primary" />
              <h3 class="mt-5 text-base font-semibold">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background px-4 py-14 md:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <Badge variant="secondary">Deploy how you want</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Simple, aggressive pricing.</h2>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-3">
        <article class="flex flex-col rounded-lg border bg-card p-5">
          <Zap className="size-5 text-primary" />
          <h3 class="mt-5 font-semibold">Free</h3>
          <p class="mt-1 text-2xl font-semibold">$0</p>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            The pixel, the watchdog, and on-demand diagnostics for a single site.
          </p>
        </article>
        <article class="flex flex-col rounded-lg border bg-card p-5">
          <Cloud className="size-5 text-primary" />
          <h3 class="mt-5 font-semibold">Hosted</h3>
          <p class="mt-1 text-2xl font-semibold">$—<span class="text-sm font-normal text-muted-foreground"> /mo</span></p>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            We host everything: your pixel, endpoint, and scheduled diagnostics. Drop in the snippet and go.
          </p>
        </article>
        <article class="flex flex-col rounded-lg border bg-card p-5">
          <TerminalSquare className="size-5 text-primary" />
          <h3 class="mt-5 font-semibold">Self-hosted</h3>
          <p class="mt-1 text-2xl font-semibold">BYO</p>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            Run the API and database yourself when you need the debug loop inside your own infrastructure.
          </p>
        </article>
      </div>
    </div>
  </section>
</SiteLayout>
