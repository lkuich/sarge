---
import { Show } from "@clerk/astro/components";
import {
  ArrowRight,
  Bot,
  Bell,
  BookOpen,
  CheckCircle2,
  CircleX,
  Cloud,
  Code2,
  Database,
  Archive,
  Radio,
  Scale,
  ShieldCheck,
  Sparkles,
  TerminalSquare,
  Webhook,
  Zap,
} from "lucide-react";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import InstallPanel from "@/components/InstallPanel";
import ShaderEffect from "@/components/shaderBackground";
import SiteLayout from "@/layouts/SiteLayout.astro";

const events = [
  { name: "checkout.started", state: "accepted", tone: "border-emerald-400/40 text-emerald-200", icon: Radio },
  { name: "meta.pixel.fire", state: "observed", tone: "border-cyan-400/40 text-cyan-200", icon: TerminalSquare },
  { name: "purchase.completed", state: "missing", tone: "border-red-500/50 text-red-400", icon: CircleX, failed: true },
  { name: "agent.fix_ready", state: "ready", tone: "border-lime-300/40 text-lime-100", icon: Bot, succeeded: true },
];

const loop = [
  {
    title: "Install the (tiny) pixel",
    description: "Drop in one hosted script or give your coding agent the Sarge install brief to wire events across your app.",
    icon: Code2,
  },
  {
    title: "Watch everything fire",
    description: "Sarge records your first-party events and observes Meta, Google, and dataLayer calls on the page.",
    icon: Radio,
  },
  {
    title: "Run scheduled reviews",
    description: "On a schedule, Sarge checks your events and re-tests tracked Production URLs for new 404s, 500s, timeouts, and suspicious redirects.",
    icon: Cloud,
  },
  {
    title: "Hand off the fix",
    description: "Context enriched from the pixel, the watchdog, and historical evidence is fed directly to your coding agent to get it fixed.",
    icon: Bot,
  },
];

const useCases = [
  {
    title: "Debug real customer flows",
    description: "Inspect sessions, users, payloads, and test traffic without guessing from ad-platform dashboards.",
    icon: Radio,
  },
  {
    title: "Catch silent breakage",
    description: "Flag missing purchases, duplicate orders, malformed events, and Production pages that start failing.",
    icon: Bell,
  },
  {
    title: "Reconcile ad platforms",
    description: "Compare Meta, Google, dataLayer, partner callbacks, and first-party events against your own record.",
    icon: ShieldCheck,
  },
  {
    title: "Verify affiliate revenue",
    description: "Keep delayed conversions tied to campaign, partner, and postback evidence.",
    icon: Scale,
  },
  {
    title: "Trigger ops workflows",
    description: "Send filtered events to webhooks for n8n, Make, Zapier, Slack, CRM updates, or lead routing.",
    icon: Webhook,
  },
  {
    title: "Backfill browser blind spots",
    description: "Record authenticated server events for paid orders, refunds, subscriptions, and payment webhooks.",
    icon: Database,
  },
  {
    title: "Test without polluting reports",
    description: "Mark impersonation runs as test traffic and isolate them from real production behavior.",
    icon: Archive,
  },
  {
    title: "Hand agents the fix context",
    description: "Turn findings into copyable prompts with evidence your coding agent can act on.",
    icon: Sparkles,
  },
];

const plans = [
  {
    name: "Free",
    price: "$0",
    description: "Install Sarge, verify one project, and inspect recent debug events.",
    icon: Zap,
    cta: "Sign up free",
    href: "/sign-up",
    variant: "outline" as const,
    features: ["1 project", "50k events/month", "7-day retention", "Basic affiliate attribution"],
  },
  {
    name: "Starter",
    price: "$19",
    priceSuffix: " /mo",
    description: "Small-team tracking validation with server calls and partner postbacks.",
    icon: Cloud,
    cta: "Sign up",
    href: "/sign-up",
    variant: "default" as const,
    features: ["3 projects", "250k events/month", "30-day retention", "Server-side calls", "Partner postbacks", "3 webhooks"],
  },
  {
    name: "Growth",
    price: "$99",
    priceSuffix: " /mo",
    description: "Production AI review, active monitoring, and configurable attribution for ecommerce teams.",
    icon: Bot,
    cta: "Sign up",
    href: "/sign-up",
    variant: "outline" as const,
    features: ["10 projects", "2M events/month", "90-day retention", "AI review", "Tracked page monitoring", "Exports and alerts"],
  },
  {
    name: "Scale",
    price: "Contact us",
    description: "Custom volume, dedicated infrastructure, security controls, and SLA.",
    icon: ShieldCheck,
    cta: "Contact us",
    href: "mailto:hello@sargetrack.app?subject=Sarge%20Scale",
    variant: "outline" as const,
    features: ["Custom events/month", "1-year+ retention", "Dedicated endpoint", "SSO/SAML", "Audit logs", "Warehouse sync"],
  },
];

---

<SiteLayout title="Sarge | Agent-ready tracking diagnostics" shader>
  <div slot="background" class="shader-layer pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true">
    <ShaderEffect client:only="react" />
  </div>
  <section class="relative mx-auto flex min-h-[calc(100svh-5rem)] w-full max-w-6xl flex-col justify-center px-4 pb-8 pt-12 md:px-6 md:pt-20">
    <div class="max-w-4xl">
      <h1 class="max-w-5xl text-5xl font-semibold leading-[0.95] md:text-7xl lg:text-8xl">
        Do you trust your tracking?
        <!-- Catch tracking bugs before your ad platforms lie to you. -->
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-white md:text-lg">
        A tiny event pixel, a watchdog for messy media scripts, and deep agent integration to proactively find and fix tracking issues before they cost you ad spend.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <Show when="signed-out">
          <a href="/sign-up">
            <Button size="lg">
              Create account <ArrowRight className="ml-1 size-4" />
            </Button>
          </a>
          <a href="/sign-in">
            <Button size="lg" variant="outline">Sign in</Button>
          </a>
        </Show>
        <Show when="signed-in">
          <a href="/app">
            <Button size="lg">
              Open dashboard <ArrowRight className="ml-1 size-4" />
            </Button>
          </a>
        </Show>
        <a href="/docs">
          <Button size="lg" variant="outline">
            Read docs <BookOpen className="ml-1 size-4" />
          </Button>
        </a>
      </div>
    </div>

    <div class="mt-10 grid overflow-hidden rounded-lg border border-white/10 bg-background/70 backdrop-blur md:grid-cols-4">
      {
        events.map(({ name, state, tone, icon: Icon, failed, succeeded }) => (
          <div class={`grid grid-cols-[auto_1fr] gap-3 border-b border-white/10 p-4 last:border-b-0 md:border-b-0 md:border-r md:last:border-r-0 ${failed ? "bg-destructive/10" : succeeded ? "bg-success/10" : ""}`}>
            <Icon className={`mt-0.5 size-4 ${tone}`} />
            <div class="min-w-0">
              <p class="truncate font-mono text-sm">{name}</p>
              <p class={`mt-1 text-xs ${failed ? "font-semibold text-red-400" : succeeded ? "font-semibold text-green-400" : "text-muted-foreground"}`}>{state}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="border-y bg-background/88 px-4 py-12 backdrop-blur md:px-6">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[320px_1fr]">
      <div>
        <Badge variant="outline">Closed loop</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-4xl">From fired event to fix prompt.</h2>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          The product is not another passive analytics dashboard. It records what happened, checks what looks wrong, and prepares the exact implementation brief a coding agent needs.
        </p>
      </div>

      <div class="grid gap-3 md:grid-cols-2">
        {
          loop.map(({ title, description, icon: Icon }, index) => (
            <article class="rounded-lg border bg-card/80 p-5">
              <div class="flex items-center gap-3">
                <span class="grid size-8 place-items-center rounded-md border bg-muted font-mono text-xs">{index + 1}</span>
                <Icon className="size-6 text-primary" />
              </div>
              <h3 class="mt-5 text-lg font-semibold">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="setup" class="scroll-mt-20 bg-background px-4 py-14 md:px-6">
    <div class="mx-auto max-w-3xl">
      <Badge variant="secondary">Setup</Badge>
      <h2 class="mt-4 text-3xl font-semibold md:text-4xl">Setup with your coding agent.</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">
        Drop in a ready-to-use Sarge prompt to get up and running with your coding agent in no time.
      </p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        <a class="inline-flex items-center font-medium text-primary hover:underline" href="/docs/events">
          Event reference <ArrowRight className="ml-1 size-3.5" />
        </a>
        <a class="inline-flex items-center font-medium text-primary hover:underline" href="/docs/self-hosting">
          Self-hosting docs <ArrowRight className="ml-1 size-3.5" />
        </a>
      </div>
      <div class="mt-6 min-h-54">
        <InstallPanel client:only="react" />
      </div>
    </div>
  </section>

  <section id="use-cases" class="scroll-mt-20 border-y bg-muted/35 px-4 py-14 md:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <Badge variant="outline">Use cases</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Turn tracking evidence into fixes, alerts, and clean handoffs.</h2>
        <p class="mt-4 text-sm leading-6 text-white">
          Sarge gives you an environment-scoped record of what fired in the browser, what arrived from your backend, what partners reported, and what broke later.
        </p>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        {
          useCases.map(({ title, description, icon: Icon }) => (
            <article class="rounded-lg border bg-card p-5">
              <Icon className="size-5 text-primary" />
              <h3 class="mt-5 text-base font-semibold">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="pricing" class="scroll-mt-20 bg-background px-4 py-14 md:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <Badge variant="secondary">Pricing</Badge>
        <h2 class="mt-4 text-3xl font-semibold md:text-5xl">Simple pricing.</h2>
        <p class="mt-4 text-sm leading-6 text-muted-foreground">
          Start with the core tracking loop for free, then add server-side calls, AI review, active page monitoring, and team controls as the stakes rise.
        </p>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        {
          plans.map(({ name, price, pricePrefix, priceSuffix, description, icon: Icon, cta, href, variant, features }) => (
            <article class="flex flex-col rounded-lg border bg-card p-5">
              <Icon className="size-5 text-primary" />
              <h3 class="mt-5 font-semibold">{name}</h3>
              <p class="mt-1 text-2xl font-semibold">
                {pricePrefix && <span class="text-sm font-normal text-muted-foreground">{pricePrefix}</span>}
                {price}
                {priceSuffix && <span class="text-sm font-normal text-muted-foreground">{priceSuffix}</span>}
              </p>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">{description}</p>
              <ul class="mt-5 space-y-2 text-sm text-muted-foreground">
                {features.map((feature) => (
                  <li class="flex gap-2">
                    <CheckCircle2 className="mt-0.5 size-4 shrink-0 text-primary" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-auto pt-5">
                <a href={href}>
                  <Button variant={variant} className="w-full">
                    {cta} <ArrowRight className="ml-1 size-3.5" />
                  </Button>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <footer class="border-t bg-background/80 px-4 py-12 backdrop-blur md:px-6">
    <div class="mx-auto grid max-w-6xl gap-8 sm:grid-cols-2 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <img class="h-7 w-auto dark:hidden" src="/sarge-logo-light.svg" alt="Sarge" width="196" height="48" />
        <img class="hidden h-7 w-auto dark:block" src="/sarge-logo-dark.svg" alt="Sarge" width="196" height="48" />
        <p class="mt-3 max-w-xs text-sm leading-6 text-muted-foreground">
          Catch tracking bugs before your ad platforms lie to you.
        </p>
      </div>

      <nav aria-label="Product">
        <p class="text-sm font-semibold">Product</p>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li><a class="transition hover:text-foreground" href="#setup">Setup</a></li>
          <li><a class="transition hover:text-foreground" href="#use-cases">Use cases</a></li>
          <li><a class="transition hover:text-foreground" href="#pricing">Pricing</a></li>
        </ul>
      </nav>

      <nav aria-label="Account">
        <p class="text-sm font-semibold">Account</p>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <Show when="signed-out">
            <li>
              <a class="transition hover:text-foreground" href="/sign-in">Sign in</a>
            </li>
            <li>
              <a class="transition hover:text-foreground" href="/sign-up">Create account</a>
            </li>
          </Show>
          <Show when="signed-in">
            <li><a class="transition hover:text-foreground" href="/app">Dashboard</a></li>
          </Show>
        </ul>
      </nav>
    </div>

    <div class="mx-auto mt-10 flex max-w-6xl flex-col items-center justify-between gap-2 border-t pt-6 text-xs text-muted-foreground sm:flex-row">
      <p>© 2026 Sarge. All rights reserved.</p>
      <p>The idiot's pixel, with an AI review loop.</p>
    </div>
  </footer>
</SiteLayout>
