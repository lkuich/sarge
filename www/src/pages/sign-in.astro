---
import { SignIn } from "@clerk/astro/components";
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout title="Sign in | Sarge">
  <section class="auth-page">
    <SignIn forceRedirectUrl="/app" fallbackRedirectUrl="/app" signUpUrl="/sign-up" />
  </section>
</SiteLayout>

<style>
  .auth-page {
    display: grid;
    min-height: calc(100vh - 72px);
    place-items: center;
    padding: 2rem 0 4rem;
  }
</style>
