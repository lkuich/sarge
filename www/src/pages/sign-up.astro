---
import { SignUp } from "@clerk/astro/components";
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout title="Sign up | Sarge">
  <section class="auth-page">
    <div class="grid gap-4">
      <SignUp forceRedirectUrl="/app" fallbackRedirectUrl="/app" signInUrl="/sign-in" />
      <p class="mx-auto max-w-sm text-center text-xs leading-5 text-muted-foreground">
        By creating an account, you agree to the <a class="font-medium text-foreground underline underline-offset-4" href="/legal/terms">Terms of Service</a>
        and acknowledge the <a class="font-medium text-foreground underline underline-offset-4" href="/legal/privacy">Privacy Policy</a>.
      </p>
    </div>
  </section>
</SiteLayout>

<style>
  .auth-page {
    display: grid;
    min-height: calc(100vh - 72px);
    place-items: center;
    padding: 2rem 0 4rem;
  }
</style>
