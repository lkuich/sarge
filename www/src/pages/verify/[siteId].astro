---
import { env } from "cloudflare:workers";
import { ExternalLink, Radio, RefreshCw, Search, TerminalSquare } from "lucide-react";
import { Badge } from "@/components/ui/badge";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getPublicEventStream } from "@/lib/sarge-demo";

export const prerender = false;

const siteId = Astro.params.siteId ?? "";
const stream = await getPublicEventStream(siteId, env.DATABASE_URL);
Astro.response.headers.set("Cache-Control", "no-store");

const formatEventTime = (value: string) =>
  new Intl.DateTimeFormat("en-US", {
    hour: "numeric",
    minute: "2-digit",
    second: "2-digit",
  }).format(new Date(value));

const formatFullTime = (value: string) => new Date(value).toLocaleString();
const formatEventPayload = (value: Record<string, unknown>) => JSON.stringify(value, null, 2);
const isWatchdogEvent = (name: string) =>
  name === "meta.pixel.fire" || name === "google.tag.fire" || name === "data_layer.push";
---

<SiteLayout title={stream ? `${stream.project.name} event stream | Sarge` : "Event stream | Sarge"}>
  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6">
    {
      stream ? (
        <>
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <Badge variant="outline">Temporary public verification</Badge>
              <h1 class="mt-4 text-3xl font-semibold tracking-tight md:text-5xl">{stream.project.name}</h1>
              <p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">
                Recent events for this Sarge site. This page auto-refreshes every 8 seconds so agents can verify tracking while exercising the target app.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <a
                class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md border bg-background px-2.5 text-sm font-medium transition hover:bg-muted"
                href={stream.project.pixelUrl}
                target="_blank"
                rel="noreferrer"
              >
                <ExternalLink className="size-4" /> Pixel
              </a>
              <a
                class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md border bg-background px-2.5 text-sm font-medium transition hover:bg-muted"
                href={stream.project.endpointHealthUrl}
                target="_blank"
                rel="noreferrer"
              >
                <ExternalLink className="size-4" /> Health
              </a>
            </div>
          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-3">
            <Card>
              <CardHeader className="pb-2">
                <CardTitle className="text-sm font-medium">Status</CardTitle>
              </CardHeader>
              <CardContent>
                <Badge>{stream.project.status}</Badge>
              </CardContent>
            </Card>
            <Card>
              <CardHeader className="pb-2">
                <CardTitle className="text-sm font-medium">Events shown</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-2xl font-semibold">{stream.events.length}</p>
              </CardContent>
            </Card>
            <Card>
              <CardHeader className="pb-2">
                <CardTitle className="text-sm font-medium">Site id</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="truncate font-mono text-xs">{stream.project.id}</p>
              </CardContent>
            </Card>
          </div>

          <Card className="mt-6">
            <CardHeader>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <CardTitle>Event stream</CardTitle>
                <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground">
                  <RefreshCw className="size-3.5" /> Auto-refreshing
                </span>
              </div>
            </CardHeader>
            <CardContent>
              {
                stream.events.length > 0 ? (
                  <Table>
                    <TableHeader>
                      <TableRow>
                        <TableHead>Event</TableHead>
                        <TableHead>Page</TableHead>
                        <TableHead>Session</TableHead>
                        <TableHead className="text-right">Time</TableHead>
                        <TableHead className="text-right">Details</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {stream.events.map((event) => (
                        <>
                          <TableRow>
                            <TableCell>
                              <div class="flex items-center gap-2">
                                {isWatchdogEvent(event.name) ? (
                                  <TerminalSquare className="size-4 text-cyan-400" />
                                ) : (
                                  <Radio className="size-4 text-primary" />
                                )}
                                <span class="font-mono text-sm">{event.name}</span>
                              </div>
                            </TableCell>
                            <TableCell>
                              <p class="max-w-xs truncate text-xs text-muted-foreground">{event.title ?? event.url ?? "No page context"}</p>
                            </TableCell>
                            <TableCell className="font-mono text-xs">{event.sessionId}</TableCell>
                            <TableCell className="text-right text-xs">{formatEventTime(event.occurredAt)}</TableCell>
                            <TableCell className="text-right">
                              <button
                                class="inline-flex h-7 items-center justify-center gap-1 rounded-md border px-2 text-xs font-medium hover:bg-muted"
                                type="button"
                                data-open-event
                                data-event-dialog={`event-${event.id}`}
                              >
                                <Search className="size-3" /> Details
                              </button>
                            </TableCell>
                          </TableRow>
                          <dialog id={`event-${event.id}`} class="w-[min(760px,calc(100vw-2rem))] rounded-lg border bg-card p-0 text-card-foreground shadow-xl backdrop:bg-black/20">
                            <div class="border-b p-4">
                              <p class="font-mono text-sm">{event.name}</p>
                              <p class="mt-1 text-xs text-muted-foreground">{event.url ?? "No URL recorded"}</p>
                            </div>
                            <div class="grid gap-4 p-4 text-sm">
                              <div class="grid gap-3 sm:grid-cols-2">
                                <div>
                                  <p class="text-xs text-muted-foreground">Session</p>
                                  <p class="mt-1 truncate font-mono">{event.sessionId}</p>
                                </div>
                                <div>
                                  <p class="text-xs text-muted-foreground">User</p>
                                  <p class="mt-1 truncate font-mono">{event.userId}</p>
                                </div>
                                <div>
                                  <p class="text-xs text-muted-foreground">Occurred</p>
                                  <p class="mt-1">{formatFullTime(event.occurredAt)}</p>
                                </div>
                                <div>
                                  <p class="text-xs text-muted-foreground">Received</p>
                                  <p class="mt-1">{formatFullTime(event.receivedAt)}</p>
                                </div>
                              </div>
                              <div>
                                <p class="text-xs text-muted-foreground">Properties</p>
                                <pre class="mt-2 max-h-72 overflow-auto rounded-md border bg-muted p-3 text-xs leading-5"><code>{formatEventPayload(event.properties)}</code></pre>
                              </div>
                            </div>
                            <div class="flex justify-end border-t p-3">
                              <button class="h-8 rounded-md border px-3 text-sm font-medium hover:bg-muted" type="button" data-close-event>Close</button>
                            </div>
                          </dialog>
                        </>
                      ))}
                    </TableBody>
                  </Table>
                ) : (
                  <div class="rounded-md border border-dashed p-6">
                    <p class="font-medium">No events received yet</p>
                    <p class="mt-2 text-sm text-muted-foreground">Trigger a page view or ecommerce action in the target app, then wait for this page to refresh.</p>
                  </div>
                )
              }
            </CardContent>
          </Card>
        </>
      ) : (
        <Card>
          <CardHeader>
            <CardTitle>Event stream unavailable</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">No public stream was found for this site id.</p>
          </CardContent>
        </Card>
      )
    }
  </section>

  <script is:inline>
    window.setTimeout(() => window.location.reload(), 8000);

    document.querySelectorAll("[data-open-event]").forEach((button) => {
      button.addEventListener("click", () => {
        const dialog = document.getElementById(button.dataset.eventDialog || "");
        if (dialog instanceof HTMLDialogElement) dialog.showModal();
      });
    });

    document.querySelectorAll("[data-close-event]").forEach((button) => {
      button.addEventListener("click", () => {
        button.closest("dialog")?.close();
      });
    });
  </script>
</SiteLayout>
